---
interface Props {
  variant?: 'primary' | 'secondary' | 'danger' | 'ghost' | 'outline';
  size?: 'sm' | 'md' | 'lg' | 'icon';
  type?: 'button' | 'submit' | 'reset';
  class?: string;
  id?: string;
  disabled?: boolean;
}

const { 
  variant = 'primary', 
  size = 'md', 
  type = 'button', 
  class: className = '', 
  id,
  disabled = false,
  ...rest
} = Astro.props;

const variantClasses = {
  primary: 'bg-forge-accent text-black hover:bg-forge-accent/90 border-transparent',
  secondary: 'bg-forge-secondary text-black hover:bg-forge-secondary/90 border-transparent',
  danger: 'bg-red-500/20 text-red-500 hover:bg-red-500/30 border-transparent',
  ghost: 'bg-transparent text-forge-text hover:bg-forge-panel border-transparent',
  outline: 'bg-transparent text-forge-text border-forge-border hover:bg-forge-panel',
};

const sizeClasses = {
  sm: 'px-2.5 py-1.5 text-xs',
  md: 'px-4 py-2 text-sm',
  lg: 'px-6 py-3 text-base',
  icon: 'p-2',
};

const baseClasses = 'inline-flex items-center justify-center font-medium transition-colors focus:outline-none focus:ring-2 focus:ring-forge-accent focus:ring-offset-2 focus:ring-offset-forge-bg disabled:opacity-50 disabled:pointer-events-none rounded-lg border';
const classes = `${baseClasses} ${variantClasses[variant]} ${sizeClasses[size]} ${className}`;
---
<button id={id} type={type} class={classes} disabled={disabled} {...rest}>
  <slot />
</button>
