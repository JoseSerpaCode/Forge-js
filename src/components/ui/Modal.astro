---
interface Props {
  id: string;
  title: string;
  class?: string;
  size?: 'sm' | 'md' | 'lg' | 'xl' | 'full';
}

const { id, title, class: className = '', size = 'md' } = Astro.props;

const sizeClasses = {
  sm: 'max-w-sm',
  md: 'max-w-lg',
  lg: 'max-w-2xl',
  xl: 'max-w-4xl',
  full: 'w-full h-full sm:w-[90vw] sm:h-[90vh]',
};

const baseContainerClasses = 'fixed inset-0 z-50 flex items-center justify-center p-4 sm:p-6';
---
<div id={`${id}-backdrop`} class={`${baseContainerClasses} hidden`}>
  <!-- Overlay -->
  <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" onclick={`document.getElementById('${id}-backdrop').classList.add('hidden')`}></div>
  
  <!-- Modal Content -->
  <div id={id} class={`relative bg-forge-panel border border-forge-border rounded-xl shadow-2xl flex flex-col overflow-hidden w-full ${sizeClasses[size]} ${className}`}>
    <!-- Header -->
    <div class="px-6 py-4 border-b border-forge-border flex items-center justify-between shrink-0 bg-forge-panel/50">
      <h2 class="text-lg font-bold text-forge-text" id={`${id}-title`}>{title}</h2>
      <button type="button" class="text-forge-muted hover:text-forge-text transition-colors p-1 rounded-md hover:bg-forge-bg" onclick={`document.getElementById('${id}-backdrop').classList.add('hidden')`}>
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
      </button>
    </div>
    
    <!-- Body -->
    <div class="flex-1 overflow-y-auto p-6 min-h-0">
      <slot />
    </div>
    
    <!-- Footer (Optional) -->
    <slot name="footer" />
  </div>
</div>
