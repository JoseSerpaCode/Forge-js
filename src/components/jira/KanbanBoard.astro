---
import BoardColumn from './BoardColumn.astro';
import IssueCard from './IssueCard.astro';
import IssueDetailsModal from './IssueDetailsModal.astro';

interface Props {
  issues: any[];
  workspaceId: string;
  sprints?: any[];
  currentSprintId?: string | null;
  workspaceMembers?: any[];
}

const { issues, workspaceId, sprints = [], currentSprintId = null, workspaceMembers = [] } = Astro.props;

const columns = [
  { id: 'todo', title: 'To Do' },
  { id: 'in_progress', title: 'In Progress' },
  { id: 'review', title: 'Review' },
  { id: 'done', title: 'Done' }
];

// Helper para extraer iniciales
function getInitials(username: string) {
  if (!username) return 'UN';
  return username.substring(0, 2).toUpperCase();
}
---
<div class="h-full flex flex-col">
  <div class="flex gap-4 h-full overflow-x-auto pb-4 kanban-container" data-workspace={workspaceId}>
    {columns.map(col => (
      <BoardColumn title={col.title} status={col.id}>
        {issues.filter(i => i.status === col.id).map(issue => (
          <IssueCard issue={{
            id: issue.id,
            title: issue.title,
            description: issue.description,
            type: issue.type,
            story_points: issue.story_points || 0,
            assignee_avatar: issue.assignee_avatar,
            assignee_username: issue.assignee_username,
            reporter_username: issue.reporter_username,
            assignee_id: issue.assignee_id,
            reporter_id: issue.reporter_id,
            position: issue.position || 0,
            sprint_id: issue.sprint_id || 'backlog'
          }} />
        ))}
      </BoardColumn>
    ))}
  </div>
</div>

<IssueDetailsModal sprints={sprints} currentSprintId={currentSprintId} workspaceMembers={workspaceMembers} />

<script>
  const columns = document.querySelectorAll('.board-column');
  const cards = document.querySelectorAll('.issue-card');
  const container = document.querySelector('.kanban-container');
  const workspaceId = container?.getAttribute('data-workspace');

  // Inicializar conteos
  const updateCounts = () => {
    columns.forEach(col => {
      const count = col.querySelectorAll('.issue-card').length;
      const countBadge = col.querySelector('.issue-count');
      if (countBadge) countBadge.textContent = count.toString();
    });
  };
  updateCounts();

  cards.forEach(card => {
    card.addEventListener('dragstart', (e: any) => {
      e.dataTransfer.setData('text/plain', card.id);
      card.classList.add('opacity-50');
      // Set drag effect
      e.dataTransfer.effectAllowed = 'move';
    });

    card.addEventListener('dragend', () => {
      card.classList.remove('opacity-50');
      columns.forEach(c => {
        const content = c.querySelector('.column-content');
        if (content) content.classList.remove('bg-forge-secondary/10');
      });
    });
    
    // Modal logic
    card.addEventListener('click', () => {
      try {
        const modal = document.getElementById('issue-details-modal');
        const titleEl = document.getElementById('modal-issue-title');
        const idEl = document.getElementById('modal-issue-id');
        const descEl = document.getElementById('modal-issue-desc') as HTMLTextAreaElement;
        const pointsEl = document.getElementById('modal-issue-points') as HTMLInputElement;
        
        if (!modal || !titleEl || !idEl || !descEl || !pointsEl) {
          alert('Missing elements: ' + [modal, titleEl, idEl, descEl, pointsEl].map(e => !!e).join(', '));
          return;
        }

        if (modal && titleEl && idEl && descEl && pointsEl) {
          idEl.textContent = card.id.substring(0, 8).toUpperCase();
          idEl.setAttribute('data-full-id', card.id);
          (titleEl as HTMLInputElement).value = card.querySelector('h4')?.textContent || '';
          descEl.value = card.querySelector('p')?.textContent || '';
          pointsEl.value = card.getAttribute('data-points') || '0';
          
          const sprintEl = document.getElementById('modal-issue-sprint') as HTMLSelectElement;
          if (sprintEl) {
            sprintEl.value = card.getAttribute('data-sprint-id') || 'backlog';
          }

          const typeBadge = card.querySelector('.issue-type-badge');
          const typeEl = document.getElementById('modal-issue-type') as HTMLSelectElement;
          if (typeBadge && typeEl) {
            const t = typeBadge.textContent?.toLowerCase().trim();
            if (t === 'task' || t === 'bug' || t === 'story') {
               typeEl.value = t;
            }
          }
          
          // Update Assignee and Reporter
          const assigneeId = card.getAttribute('data-assignee-id');
          const reporterId = card.getAttribute('data-reporter-id');
          
          const assigneeSelect = document.getElementById('modal-issue-assignee') as HTMLSelectElement;
          const reporterSelect = document.getElementById('modal-issue-reporter') as HTMLSelectElement;
          
          if (assigneeSelect) assigneeSelect.value = assigneeId || '';
          if (reporterSelect) reporterSelect.value = reporterId || 'system';
          
          // @ts-ignore
          if (window.loadIssueAttachments) window.loadIssueAttachments(card.id);

          modal.classList.remove('translate-x-full');
          document.getElementById('issue-details-backdrop')?.classList.remove('hidden');
        }
      } catch (err: any) {
        alert('Error opening modal: ' + err.message + '\n' + err.stack);
      }
    });
  });

  // Helper to determine insert position
  function getDragAfterElement(container: Element, y: number) {
    const draggableElements = [...container.querySelectorAll('.issue-card:not(.opacity-50)')];
    
    return draggableElements.reduce((closest, child) => {
      const box = child.getBoundingClientRect();
      const offset = y - box.top - box.height / 2;
      if (offset < 0 && offset > closest.offset) {
        return { offset: offset, element: child };
      } else {
        return closest;
      }
    }, { offset: Number.NEGATIVE_INFINITY, element: null as Element | null }).element;
  }

  columns.forEach(column => {
    const content = column.querySelector('.column-content');
    column.addEventListener('dragover', (e: any) => {
      e.preventDefault();
      if (content) {
        content.classList.add('bg-forge-secondary/10');
        const afterElement = getDragAfterElement(content, e.clientY);
        const draggable = document.querySelector('.opacity-50');
        if (draggable) {
          if (afterElement == null) {
            content.appendChild(draggable);
          } else {
            content.insertBefore(draggable, afterElement);
          }
        }
      }
    });

    column.addEventListener('dragleave', () => {
      if (content) content.classList.remove('bg-forge-secondary/10');
    });

    column.addEventListener('drop', async (e: any) => {
      e.preventDefault();
      if (content) content.classList.remove('bg-forge-secondary/10');
      
      const issueId = e.dataTransfer.getData('text/plain');
      const card = document.getElementById(issueId);
      const newStatus = column.getAttribute('data-status');

      if (card && content && newStatus) {
        updateCounts();
        
        // Calculate new position based on siblings
        const siblings = [...content.querySelectorAll('.issue-card')];
        const cardIndex = siblings.indexOf(card);
        
        let newPosition = 0;
        if (siblings.length === 1) {
          newPosition = 100000;
        } else if (cardIndex === 0) {
          const nextPos = parseFloat(siblings[1].getAttribute('data-position') || '100000');
          newPosition = nextPos / 2;
        } else if (cardIndex === siblings.length - 1) {
          const prevPos = parseFloat(siblings[cardIndex - 1].getAttribute('data-position') || '0');
          newPosition = prevPos + 100000;
        } else {
          const prevPos = parseFloat(siblings[cardIndex - 1].getAttribute('data-position') || '0');
          const nextPos = parseFloat(siblings[cardIndex + 1].getAttribute('data-position') || '0');
          newPosition = (prevPos + nextPos) / 2;
        }
        
        card.setAttribute('data-position', newPosition.toString());

        try {
          const response = await fetch(`/api/issues/${issueId}/move`, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ 
              status: newStatus,
              position: newPosition,
              workspaceId 
            })
          });
          
          if (!response.ok) {
            throw new Error('Failed to update status and position');
          }
        } catch (error) {
          console.error('[SYS.NET] Update failed', error);
          // Omitimos rollback visual para no complicar el script en el entorno actual
        }
      }
    });
  });

  // Check URL for issue parameter to auto-open
  window.addEventListener('DOMContentLoaded', () => {
    const urlParams = new URLSearchParams(window.location.search);
    const issueId = urlParams.get('issue');
    if (issueId) {
      const card = document.getElementById(issueId);
      if (card) {
        // Find the specific card and simulate a click on its outer div
        (card as HTMLElement).click();
        
        // Remove from URL so reloads don't reopen it
        const newUrl = new URL(window.location.href);
        newUrl.searchParams.delete('issue');
        window.history.replaceState({}, '', newUrl.toString());
      }
    }
  });
</script>
