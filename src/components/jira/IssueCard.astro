---
interface Props {
  issue: {
    id: string;
    title: string;
    description: string;
    type: string;
    story_points: number;
    assignee_initials: string;
    position: number;
    sprint_id?: string;
  };
}

const { issue } = Astro.props;
---
<!-- Componente IssueCard.astro -->
<div id={issue.id} draggable="true" data-points={issue.story_points} data-position={issue.position} data-sprint-id={issue.sprint_id || 'backlog'} class="issue-card group bg-forge-panel border border-forge-border p-4 rounded-md shadow-lg hover:border-forge-secondary transition-all cursor-grab active:cursor-grabbing mb-2">
  <div class="flex justify-between items-start mb-2">
    <span class="font-mono text-[10px] text-forge-secondary uppercase">{issue.id}</span>
    <div class="w-6 h-6 rounded-full bg-forge-bg border border-forge-border flex items-center justify-center text-[10px] text-forge-muted font-bold">
      {issue.assignee_initials}
    </div>
  </div>
  <h4 class="text-forge-text font-bold text-sm mb-1">{issue.title}</h4>
  <p class="text-forge-muted text-xs line-clamp-2 mb-3">{issue.description || 'No description provided.'}</p>
  <div class="flex items-center gap-2">
    <span class="issue-type-badge px-2 py-0.5 rounded text-[10px] font-mono bg-forge-bg text-forge-muted border border-forge-border uppercase">
      {issue.type}
    </span>
    <span class="text-[10px] text-forge-muted font-mono">{issue.story_points} SP</span>
  </div>
</div>
