---
interface Props {
  pageId: string;
  initialTitle: string;
  initialContent: string;
  canEdit: boolean;
  authorName?: string;
  authorAvatar?: string;
  updatedAt?: string;
  createdAt?: string;
  parentTitle?: string | null;
  parentId?: string | null;
  sysTag: string;
}
const { pageId, initialTitle, initialContent, canEdit, authorName, authorAvatar, updatedAt, parentTitle, parentId, sysTag } = Astro.props;

// Date formatter
function formatDate(dateStr: string | undefined) {
  if (!dateStr) return '';
  // SQLite CURRENT_TIMESTAMP is UTC: "YYYY-MM-DD HH:MM:SS"
  const safeStr = dateStr.includes('Z') ? dateStr : dateStr.replace(' ', 'T') + 'Z';
  const date = new Date(safeStr);
  
  const now = new Date();
  const diffMs = now.getTime() - date.getTime();
  const diffMins = Math.floor(diffMs / 60000);
  
  if (diffMins < 1) return 'just now';
  if (diffMins < 60) return `${diffMins} min ago`;
  if (diffMins < 120) return `1 hour ago`;
  
  const isToday = date.toDateString() === now.toDateString();
  const timeStr = date.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' });
  
  if (isToday) return `today at ${timeStr}`;
  
  const yesterday = new Date(now);
  yesterday.setDate(now.getDate() - 1);
  if (date.toDateString() === yesterday.toDateString()) return `yesterday at ${timeStr}`;
  
  return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}
---

<div class="flex-1 flex flex-col h-full bg-forge-bg overflow-y-auto">
  <div class="max-w-3xl mx-auto w-full px-8 py-12 flex flex-col min-h-full">
    
    <!-- Breadcrumbs -->
    {parentTitle && (
      <nav class="text-xs font-mono text-forge-muted mb-4 flex items-center gap-2">
        <a href={`/w/${sysTag}/p/${parentId}`} class="hover:text-forge-text transition-colors">{parentTitle}</a>
        <span class="text-forge-border">/</span>
        <span class="text-forge-text truncate">{initialTitle || 'Untitled'}</span>
      </nav>
    )}

    <!-- Title & Delete -->
    <div class="flex items-center justify-between mb-4 group relative">
      <input type="text" id="editor-title" 
        value={initialTitle}
        readonly={!canEdit}
        class="text-4xl font-bold bg-transparent text-forge-text focus:outline-none focus:border-b focus:border-forge-secondary border-b border-transparent w-full transition-colors pb-1"
        placeholder="Untitled" autocomplete="off" />
      {canEdit && (
        <button id="btn-delete-page" class="absolute -right-12 w-8 h-8 rounded flex items-center justify-center text-forge-muted hover:bg-red-500/20 hover:text-red-500 transition-colors opacity-0 group-hover:opacity-100" title="Delete Page">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
        </button>
      )}
    </div>

    <!-- Metadata Bar -->
    <div class="flex items-center gap-3 mb-10 pb-4 border-b border-forge-border/50">
      <img src={authorAvatar || '/default-avatar.svg'} class="w-6 h-6 rounded-full border border-forge-border bg-forge-panel" alt="Author" />
      <div class="flex items-center gap-2 text-xs font-mono text-forge-muted">
        <span>Forged by <span class="text-forge-text font-bold">{authorName || 'Unknown'}</span></span>
        <span class="text-forge-border">•</span>
        <span>Updated {formatDate(updatedAt)}</span>
        {initialContent === 'null' || !initialContent ? (
          <>
            <span class="text-forge-border">•</span>
            <span class="bg-forge-primary/10 text-forge-primary px-1.5 py-0.5 rounded border border-forge-primary/30">Draft</span>
          </>
        ) : null}
      </div>
      <div class="ml-auto flex items-center gap-2">
        <div class="relative group">
          <button class="text-forge-muted hover:text-forge-primary px-2 py-1.5 rounded-md transition-colors" aria-label="Editor Tips">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="M12 16v-4"></path><path d="M12 8h.01"></path></svg>
          </button>
          
          <div class="absolute right-0 top-full mt-2 w-56 bg-forge-panel border border-forge-border rounded-lg shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all z-50 p-3 text-xs text-forge-text pointer-events-none">
            <h4 class="font-bold text-forge-primary mb-2 border-b border-forge-border pb-1">Editor Shortcuts</h4>
            <ul class="space-y-2 text-forge-muted">
              <li class="flex justify-between items-center"><span>Add Block</span> <span class="font-mono text-[10px] bg-forge-bg px-1.5 py-0.5 rounded border border-forge-border/50">TAB / +</span></li>
              <li class="flex justify-between items-center"><span>Move Block</span> <span class="text-[10px]">Drag <span class="bg-forge-bg px-1 py-0.5 rounded font-bold border border-forge-border/50">::</span></span></li>
              <li class="flex justify-between items-center"><span>Undo/Redo</span> <span class="font-mono text-[10px] bg-forge-bg px-1.5 py-0.5 rounded border border-forge-border/50">Ctrl Z / Y</span></li>
              <li class="flex justify-between items-center"><span>Styles</span> <span class="font-mono text-[10px] bg-forge-bg px-1.5 py-0.5 rounded border border-forge-border/50">Ctrl B/I/U</span></li>
              <li class="flex justify-between items-center"><span>Link</span> <span class="font-mono text-[10px] bg-forge-bg px-1.5 py-0.5 rounded border border-forge-border/50">Ctrl K</span></li>
            </ul>
          </div>
        </div>

        <button id="btn-share-page" class="text-forge-muted hover:text-forge-secondary hover:bg-forge-secondary/10 px-3 py-1.5 rounded-md text-xs font-bold transition-all border border-transparent hover:border-forge-secondary/30 flex items-center gap-1" title="Copy Link to Page">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg>
          Share
        </button>
      </div>
    </div>

    <!-- Editor.js Container -->
    <div 
      id="page-editor"
      class="flex-1 text-forge-text outline-none prose dark:prose-invert max-w-none relative editor-js-container selection:bg-forge-primary selection:text-white"
      data-page-id={pageId}
      data-initial-content={initialContent}
      data-can-edit={canEdit.toString()}
    ></div>


    <div class="fixed bottom-4 right-8 flex items-center gap-2 text-xs font-mono text-forge-muted">
      <span id="save-status">Saved</span>
    </div>
  </div>
</div>

<script>
  import EditorJS from '@editorjs/editorjs';
  import Header from '@editorjs/header';
  import List from '@editorjs/list';
  // @ts-ignore
  import Checklist from '@editorjs/checklist';
  import Quote from '@editorjs/quote';
  // @ts-ignore
  import Marker from '@editorjs/marker';
  import InlineCode from '@editorjs/inline-code';
  // @ts-ignore
  import Undo from 'editorjs-undo';
  // @ts-ignore
  import Underline from '@editorjs/underline';
  // @ts-ignore
  import Table from '@editorjs/table';
  import Delimiter from '@editorjs/delimiter';
  import Warning from '@editorjs/warning';
  import CodeTool from '@editorjs/code';
  // @ts-ignore
  import DragDrop from 'editorjs-drag-drop';

  const editorDiv = document.getElementById('page-editor');
  const titleInput = document.getElementById('editor-title') as HTMLInputElement;
  const statusSpan = document.getElementById('save-status');

  if (editorDiv) {
    const pageId = editorDiv.dataset.pageId;
    const canEdit = editorDiv.dataset.canEdit === 'true';
    let initialData: any = { blocks: [] };
    try {
      if (editorDiv.dataset.initialContent && editorDiv.dataset.initialContent !== 'null') {
        initialData = JSON.parse(editorDiv.dataset.initialContent);
      }
    } catch (e) {
      console.error('Failed to parse initial content', e);
    }

    let saveTimeout: any;

    const editor = new EditorJS({
      holder: 'page-editor',
      readOnly: !canEdit,
      data: initialData,
      tools: {
        header: {
          class: Header,
          inlineToolbar: true,
          config: {
            levels: [1, 2, 3, 4, 5, 6],
            defaultLevel: 1
          }
        },
        list: {
          class: List,
          inlineToolbar: true,
        },
        checklist: {
          class: Checklist,
          inlineToolbar: true,
        },
        quote: {
          class: Quote,
          inlineToolbar: true,
        },
        marker: {
          class: Marker,
        },
        inlineCode: {
          class: InlineCode,
        },
        underline: {
          class: Underline,
        },
        table: {
          // @ts-ignore - @editorjs/table has non-standard type exports
          class: Table,
          inlineToolbar: true,
        },
        delimiter: {
          class: Delimiter,
        },
        warning: {
          class: Warning,
          inlineToolbar: true,
        },
        code: {
          class: CodeTool,
        }
      },
      onChange: () => {
        debounceSave();
      },
      onReady: () => {
        new Undo({ editor });
        new DragDrop(editor);
        // Expose for E2E testing
        (window as any).__editorInstance = editor;
      }
    });

    async function save() {
      if (!canEdit) return;
      if (statusSpan) statusSpan.textContent = 'Saving...';
      try {
        const outputData = await editor.save();
        const res = await fetch(`/api/pages/${pageId}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ 
            title: (titleInput as HTMLInputElement)?.value?.trim() || 'Untitled', 
            content_json: JSON.stringify(outputData)
          })
        });
        
        if (!res.ok) {
           const err = await res.json();
           throw new Error(err.error || 'Save failed');
        }
        if (statusSpan) statusSpan.textContent = 'Saved';
      } catch (e: any) {
        if (statusSpan) statusSpan.textContent = 'Error saving';
        window.showToast?.('Error: ' + e.message, true);
      }
    }

    function debounceSave() {
      if (statusSpan) statusSpan.textContent = 'Unsaved changes...';
      clearTimeout(saveTimeout);
      saveTimeout = setTimeout(save, 1000);
    }

    titleInput?.addEventListener('input', debounceSave);


    document.getElementById('btn-delete-page')?.addEventListener('click', async () => {
      if (!confirm('Are you sure you want to delete this page and ALL its subpages? This action cannot be undone.')) return;
      
      const res = await fetch(`/api/pages/${pageId}`, { method: 'DELETE' });
      if (res.ok) {
        // Redirect to KB home
        const sysTagMatch = window.location.pathname.match(/^\/w\/([^/]+)/);
        if (sysTagMatch) {
          window.location.href = `/w/${sysTagMatch[1]}/p`;
        }
      } else {
        window.showToast?.('Error deleting page: ' + await res.text(), true);
      }
    });

    document.getElementById('btn-share-page')?.addEventListener('click', () => {
      const url = new URL(window.location.href);
      navigator.clipboard.writeText(url.toString()).then(() => {
        if (window.showToast) window.showToast('Link copied to clipboard!');
      });
    });
  }
</script>

<style is:global>
  /* Fix EditorJS internal variables for perfect dark/light mode integration */
  .editor-js-container {
    --color-text-primary: var(--forge-text);
    --color-background-item-hover: var(--forge-bg);
    --color-background-item-focus: var(--forge-bg);
    --color-border: var(--forge-border);
  }

  .ce-popover, .ce-inline-toolbar, .ce-settings, .ce-conversion-toolbar, .tc-popover {
    --color-border: var(--forge-border) !important;
    --color-background: var(--forge-panel) !important;
    --color-text-primary: var(--forge-text) !important;
    --color-text-secondary: var(--forge-muted) !important;
    --color-border-icon: var(--forge-border) !important;
    --color-background-item-hover: var(--forge-bg) !important;
    --color-background-item-focus: var(--forge-bg) !important;
    --color-shadow: rgba(0, 0, 0, 0.3) !important;
    
    background-color: var(--forge-panel) !important;
    border: 1px solid var(--forge-border) !important;
    color: var(--forge-text) !important;
  }
  
  /* Fallbacks for older editor.js DOM elements if CSS vars aren't fully supported */
  .ce-popover-item, .tc-popover__item, .ce-inline-tool, .ce-conversion-tool {
    color: var(--forge-text) !important;
  }
  .ce-popover-item:hover, .tc-popover__item:hover, .ce-inline-tool:hover, .ce-conversion-tool:hover {
    background-color: var(--forge-bg) !important;
  }
  .ce-popover-item__title, .tc-popover__item-label {
    color: var(--forge-text) !important;
  }
  .ce-popover-item__icon, .tc-popover__item-icon {
    background-color: transparent !important;
    box-shadow: none !important;
    color: var(--forge-text) !important;
  }
  .ce-popover__search {
    background-color: var(--forge-bg) !important;
    color: var(--forge-text) !important;
    border-bottom: 1px solid var(--forge-border) !important;
  }

  /* Typography / Block Styles */
  .ce-block__content, .ce-toolbar__content {
    max-width: 800px !important;
  }
  
  .ce-header {
    color: var(--forge-text) !important;
  }
  
  .cdx-quote {
    border-left: 4px solid var(--forge-secondary) !important;
    background-color: var(--forge-bg) !important;
  }
  
  .cdx-checklist__item-checkbox {
    border: 1px solid var(--forge-border) !important;
    background: var(--forge-bg) !important;
    border-radius: 4px !important;
    margin-top: 0.25rem !important;
  }
  .cdx-checklist__item--checked .cdx-checklist__item-checkbox {
    background: var(--forge-secondary) !important;
    border-color: var(--forge-secondary) !important;
  }

  .cdx-marker {
    background-color: var(--forge-accent-primary) !important;
    color: #fff !important;
    padding: 0.1rem 0.2rem !important;
    border-radius: 3px !important;
  }

  .inline-code {
    background-color: var(--forge-bg) !important;
    border: 1px solid var(--forge-border) !important;
    padding: 0.1rem 0.3rem !important;
    border-radius: 4px !important;
    font-family: 'JetBrains Mono', monospace !important;
    font-size: 0.9em !important;
  }

  .codex-editor__redactor {
    padding-bottom: 100px !important;
  }
  .ce-block--selected .ce-block__content {
    background-color: color-mix(in srgb, var(--forge-accent-primary) 15%, transparent) !important;
  }

  /* Force override Editor.js dynamically injected selection styles */
  .editor-js-container ::selection {
    background-color: var(--forge-accent-primary) !important;
    color: #ffffff !important;
  }
  .editor-js-container *::selection {
    background-color: var(--forge-accent-primary) !important;
    color: #ffffff !important;
  }
  .ce-block__content ::selection {
    background-color: var(--forge-accent-primary) !important;
    color: #ffffff !important;
  }
  .cdx-block ::selection {
    background-color: var(--forge-accent-primary) !important;
    color: #ffffff !important;
  }
</style>
