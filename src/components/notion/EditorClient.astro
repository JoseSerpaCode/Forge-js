---
interface Props {
  pageId: string;
  initialTitle: string;
  initialContent: string;
  canEdit: boolean;
}
const { pageId, initialTitle, initialContent, canEdit } = Astro.props;
---

<div class="flex-1 flex flex-col h-full bg-forge-bg overflow-y-auto">
  <div class="max-w-4xl mx-auto w-full p-8 pt-16 flex flex-col min-h-full">
    
    <div class="flex items-center justify-between mb-8 group">
      <input 
        id="page-title"
        type="text" 
        value={initialTitle}
        readonly={!canEdit}
        class="text-4xl font-bold bg-transparent text-white focus:outline-none focus:border-b focus:border-forge-neon border-b border-transparent w-full transition-colors"
        placeholder="Page Title"
      />
      {canEdit && (
        <button id="btn-delete-page" class="w-8 h-8 rounded flex items-center justify-center text-forge-muted hover:bg-red-500/20 hover:text-red-500 transition-colors opacity-0 group-hover:opacity-100" title="Delete Page">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
        </button>
      )}
    </div>

    <!-- Editor.js Container -->
    <div 
      id="page-editor"
      class="flex-1 text-forge-text outline-none prose prose-invert max-w-none relative"
      data-page-id={pageId}
      data-initial-content={initialContent}
      data-can-edit={canEdit.toString()}
    ></div>

    <!-- Slash Menu Popover -->
    <div id="slash-menu" class="hidden absolute bg-forge-bg border border-forge-border rounded shadow-lg p-2 flex flex-col gap-1 w-48 z-50">
      <button class="slash-menu-item text-left px-2 py-1 hover:bg-forge-highlight rounded text-sm text-forge-text" data-type="header" data-level="1">H1 - Heading 1</button>
      <button class="slash-menu-item text-left px-2 py-1 hover:bg-forge-highlight rounded text-sm text-forge-text" data-type="header" data-level="2">H2 - Heading 2</button>
      <button class="slash-menu-item text-left px-2 py-1 hover:bg-forge-highlight rounded text-sm text-forge-text" data-type="list" data-style="unordered">Bulleted List</button>
      <button class="slash-menu-item text-left px-2 py-1 hover:bg-forge-highlight rounded text-sm text-forge-text" data-type="list" data-style="ordered">Numbered List</button>
      <button class="slash-menu-item text-left px-2 py-1 hover:bg-forge-highlight rounded text-sm text-forge-text" data-type="checklist">Checklist</button>
      <button class="slash-menu-item text-left px-2 py-1 hover:bg-forge-highlight rounded text-sm text-forge-text" data-type="quote">Quote</button>
    </div>

    <div class="fixed bottom-4 right-8 flex items-center gap-2 text-xs font-mono text-forge-muted">
      <span id="save-status">Saved</span>
    </div>
  </div>
</div>

<script>
  import EditorJS from '@editorjs/editorjs';
  import Header from '@editorjs/header';
  import List from '@editorjs/list';
  import Checklist from '@editorjs/checklist';
  import Quote from '@editorjs/quote';
  import Marker from '@editorjs/marker';
  import InlineCode from '@editorjs/inline-code';

  const editorDiv = document.getElementById('page-editor');
  const titleInput = document.getElementById('page-title') as HTMLInputElement;
  const statusSpan = document.getElementById('save-status');

  if (editorDiv) {
    const pageId = editorDiv.dataset.pageId;
    const canEdit = editorDiv.dataset.canEdit === 'true';
    let initialData = {};
    try {
      if (editorDiv.dataset.initialContent && editorDiv.dataset.initialContent !== 'null') {
        initialData = JSON.parse(editorDiv.dataset.initialContent);
      }
    } catch (e) {
      console.error('Failed to parse initial content', e);
    }

    let saveTimeout: any;

    const editor = new EditorJS({
      holder: 'page-editor',
      readOnly: !canEdit,
      data: initialData,
      tools: {
        header: {
          class: Header,
          config: {
            levels: [1, 2, 3, 4, 5, 6],
            defaultLevel: 1
          }
        },
        list: List,
        checklist: Checklist,
        quote: Quote,
        marker: Marker,
        inlineCode: InlineCode
      },
      onChange: () => {
        debounceSave();
      }
    });

    async function save() {
      if (!canEdit) return;
      if (statusSpan) statusSpan.textContent = 'Saving...';
      try {
        const outputData = await editor.save();
        const res = await fetch(`/api/pages/${pageId}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ 
            title: titleInput?.value, 
            content_json: JSON.stringify(outputData)
          })
        });
        
        if (!res.ok) {
           const err = await res.json();
           throw new Error(err.error || 'Save failed');
        }
        if (statusSpan) statusSpan.textContent = 'Saved';
      } catch (e: any) {
        if (statusSpan) statusSpan.textContent = 'Error saving';
        alert('Error: ' + e.message);
      }
    }

    function debounceSave() {
      if (statusSpan) statusSpan.textContent = 'Unsaved changes...';
      clearTimeout(saveTimeout);
      saveTimeout = setTimeout(save, 1000);
    }

    titleInput?.addEventListener('input', debounceSave);

    const slashMenu = document.getElementById('slash-menu');
    let currentBlockIndex = -1;

    editorDiv.addEventListener('keyup', (e) => {
      if (!slashMenu || !canEdit) return;
      
      const currentBlockIndexApi = editor.blocks.getCurrentBlockIndex();
      if (currentBlockIndexApi < 0) return;
      
      const currentBlock = editor.blocks.getBlockByIndex(currentBlockIndexApi);
      if (!currentBlock) return;

      const textNode = currentBlock.holder.querySelector('.ce-paragraph');
      if (!textNode) {
        slashMenu.classList.add('hidden');
        return;
      }

      const text = textNode.textContent || '';
      const cleanText = text.replace(/[\u200B-\u200D\uFEFF]/g, '').trim();
      if (cleanText === '/') {
        const selection = window.getSelection();
        if (selection && selection.rangeCount > 0) {
          const range = selection.getRangeAt(0);
          const rect = range.getBoundingClientRect();
          slashMenu.style.top = `${rect.bottom + window.scrollY}px`;
          slashMenu.style.left = `${rect.left + window.scrollX}px`;
        } else {
          slashMenu.style.top = '100px';
          slashMenu.style.left = '100px';
        }
        slashMenu.classList.remove('hidden');
        currentBlockIndex = currentBlockIndexApi;
      } else {
        slashMenu.classList.add('hidden');
      }
    });

    document.querySelectorAll('.slash-menu-item').forEach(item => {
      item.addEventListener('click', async (e) => {
        if (!canEdit) return;
        const target = e.currentTarget as HTMLElement;
        const type = target.dataset.type;
        const level = target.dataset.level;
        const style = target.dataset.style;
        
        if (currentBlockIndex >= 0 && type) {
          editor.blocks.delete(currentBlockIndex);
          
          let data: any = {};
          if (level) data.level = parseInt(level);
          if (style) data.style = style;
          
          editor.blocks.insert(type, data, {}, currentBlockIndex, true);
          editor.caret.setToBlock(currentBlockIndex, 'start');
        }
        
        slashMenu?.classList.add('hidden');
      });
    });

    document.addEventListener('click', (e) => {
      if (slashMenu && !slashMenu.contains(e.target as Node) && !(e.target as Element).closest('#page-editor')) {
        slashMenu.classList.add('hidden');
      }
    });

    document.getElementById('btn-delete-page')?.addEventListener('click', async () => {
      if (!confirm('Are you sure you want to delete this page and ALL its subpages? This action cannot be undone.')) return;
      
      const res = await fetch(`/api/pages/${pageId}`, { method: 'DELETE' });
      if (res.ok) {
        // Redirect to KB home
        const sysTagMatch = window.location.pathname.match(/^\/w\/([^/]+)/);
        if (sysTagMatch) {
          window.location.href = `/w/${sysTagMatch[1]}/p`;
        }
      } else {
        alert('Error deleting page: ' + await res.text());
      }
    });
  }
</script>
