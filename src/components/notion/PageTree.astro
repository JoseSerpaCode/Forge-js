---
import db from '../../lib/db';
import PageTreeItem from './PageTreeItem.astro';
import { checkWorkspaceAccess } from '../../lib/guard';

interface Props {
  workspaceId: string;
  sysTag: string;
  currentPageId?: string;
}

const { workspaceId, sysTag, currentPageId } = Astro.props;
const user = Astro.locals.user!;
if (!user) return new Response('Unauthorized', { status: 401 });

// Check access (viewer minimum)
const access = checkWorkspaceAccess(user.id, user.is_sysadmin, workspaceId, 'viewer');
if (!access.granted) return new Response(access.error, { status: 403 });

// One single query for the whole tree
const pages = db.prepare('SELECT id, parent_page_id, title, icon FROM pages WHERE workspace_id = ? ORDER BY created_at ASC').all(workspaceId) as any[];

const childrenMap = new Map<string, any[]>();
const rootPages: any[] = [];

for (const p of pages) {
  if (!p.parent_page_id) {
    rootPages.push(p);
  } else {
    if (!childrenMap.has(p.parent_page_id)) childrenMap.set(p.parent_page_id, []);
    childrenMap.get(p.parent_page_id)!.push(p);
  }
}
---

<aside id="page-tree-aside" data-workspace-id={workspaceId} class="w-64 bg-forge-panel border border-forge-border rounded-lg m-4 flex flex-col h-[calc(100%-2rem)] shrink-0 transition-all duration-300 relative">
  <div class="p-4 border-b border-forge-border flex items-center justify-between">
    <h2 class="font-bold text-forge-text uppercase tracking-widest text-sm flex items-center gap-2 transition-opacity duration-300" id="page-tree-title">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-forge-secondary"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"></path></svg>
      Knowledge Base
    </h2>
    <div class="flex items-center gap-2">
      <button id="btn-new-root-page" class="w-6 h-6 flex items-center justify-center bg-forge-bg hover:bg-forge-primary hover:text-forge-bg rounded border border-forge-border transition-colors" title="New Page">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
      </button>
      <button id="btn-toggle-tree" class="w-6 h-6 flex items-center justify-center text-forge-muted hover:text-forge-text rounded transition-colors" title="Toggle Sidebar">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><path d="M9 3v18"/></svg>
      </button>
    </div>
  </div>
  
  <div class="flex-1 overflow-y-auto p-2">
    <ul id="page-tree-root" class="space-y-1">
      {rootPages.length === 0 ? (
        <li class="p-6 mt-4 mx-2 flex flex-col items-center justify-center text-center relative overflow-hidden border border-dashed border-forge-border rounded bg-forge-panel/30">
          <div class="absolute inset-0 opacity-20 pointer-events-none" style="background-image: radial-gradient(circle at 50% 30%, var(--forge-muted) 2px, transparent 2px), radial-gradient(circle at 20% 70%, var(--forge-muted) 2px, transparent 2px), radial-gradient(circle at 80% 80%, var(--forge-muted) 2px, transparent 2px); background-size: 100% 100%;">
            <svg class="w-full h-full" viewBox="0 0 100 100" preserveAspectRatio="none"><path d="M 50 30 L 20 70 L 80 80 Z" fill="none" stroke="currentColor" class="text-forge-muted" stroke-dasharray="2,2" stroke-width="0.5" /></svg>
          </div>
          <p class="text-forge-muted font-mono mb-2 relative z-10 text-[10px]">EMPTY_SPACE</p>
          <p class="text-forge-text relative z-10 text-xs">No pages yet.</p>
        </li>
      ) : (
        rootPages.map(page => (
          <PageTreeItem page={page} childrenMap={childrenMap} currentPageId={currentPageId} sys_tag={sysTag} />
        ))
      )}
    </ul>
  </div>
</aside>

<script>
  // Handle toggling of folders
  document.getElementById('page-tree-root')?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('button[aria-label="Toggle"]');
    if (btn) {
      e.preventDefault();
      e.stopPropagation();
      const parentLi = btn.closest('li');
      const childrenUl = parentLi?.querySelector('ul');
      const icon = btn.querySelector('svg');
      if (childrenUl && parentLi) {
        parentLi.classList.toggle('expanded');
        childrenUl.classList.toggle('hidden');
        if (icon) icon.classList.toggle('rotate-90');
      }
    }
  });

  // Automatically expand folders that contain the active page
  const activeLink = document.querySelector('a.text-forge-text.font-bold');
  if (activeLink) {
    let parent = activeLink.parentElement?.parentElement; // li
    while (parent && parent.tagName === 'LI') {
      parent.classList.add('expanded');
      const ul = parent.querySelector(':scope > ul');
      if (ul) ul.classList.remove('hidden');
      const icon = parent.querySelector(':scope > div button[aria-label="Toggle"] svg');
      if (icon) icon.classList.add('rotate-90');
      
      parent = parent.parentElement?.parentElement; // go up to next li
    }
  }

  // Create page logic
  async function createPage(parentId: string | null) {
    const sysTagMatch = window.location.pathname.match(/^\/w\/([^/]+)/);
    const sysTag = sysTagMatch ? sysTagMatch[1] : '';
    
    // We need the workspace UUID. We can get it from the dataset.
    const aside = document.getElementById('page-tree-aside');
    const workspaceId = aside?.getAttribute('data-workspace-id');

    const res = await fetch('/api/pages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ title: 'Untitled', parent_page_id: parentId, workspace_id: workspaceId })
    });
    if (res.ok) {
      const data = await res.json();
      // Wait for sysTag from URL
      const sysTagMatch = window.location.pathname.match(/^\/w\/([^/]+)/);
      const sysTag = sysTagMatch ? sysTagMatch[1] : '';
      if (sysTag) {
        window.location.href = `/w/${sysTag}/p/${data.id}`;
      }
    } else {
      alert('Error creating page: ' + await res.text());
    }
  }

  document.getElementById('btn-new-root-page')?.addEventListener('click', () => createPage(null));
  
  document.querySelectorAll('.add-child-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      const parentId = btn.getAttribute('data-parent-id');
      if (parentId) createPage(parentId);
    });
  });

  document.querySelectorAll('.delete-tree-page-btn').forEach(btn => {
    btn.addEventListener('click', async (e) => {
      e.preventDefault();
      e.stopPropagation();
      const id = btn.getAttribute('data-id');
      if (!id) return;
      
      // @ts-ignore
      window.forgeConfirm('Are you sure you want to delete this page and all its subpages?', async () => {
        const res = await fetch(`/api/pages/${id}`, { method: 'DELETE' });
        if (res.ok) {
          // Check if we are currently on the deleted page
          const sysTagMatch = window.location.pathname.match(/^\/w\/([^/]+)/);
          const sysTag = sysTagMatch ? sysTagMatch[1] : '';
          if (window.location.pathname.includes(`/p/${id}`)) {
            window.location.href = `/w/${sysTag}/p`;
          } else {
            window.location.reload();
          }
        } else {
          // @ts-ignore
          window.showToast('Failed to delete: ' + await res.text(), true);
        }
      });
    });
  });

  // Toggle PageTree Sidebar logic
  const toggleBtn = document.getElementById('btn-toggle-tree');
  const aside = document.getElementById('page-tree-aside');
  const title = document.getElementById('page-tree-title');
  const newRootBtn = document.getElementById('btn-new-root-page');
  const treeRoot = document.getElementById('page-tree-root');

  let isCollapsed = false;
  toggleBtn?.addEventListener('click', () => {
    isCollapsed = !isCollapsed;
    if (isCollapsed) {
      aside?.classList.remove('w-64');
      aside?.classList.add('w-16');
      title?.classList.add('opacity-0', 'pointer-events-none', 'w-0', 'overflow-hidden');
      if (newRootBtn) newRootBtn.style.display = 'none';
      if (treeRoot) treeRoot.style.display = 'none';
      toggleBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>';
    } else {
      aside?.classList.remove('w-16');
      aside?.classList.add('w-64');
      title?.classList.remove('opacity-0', 'pointer-events-none', 'w-0', 'overflow-hidden');
      if (newRootBtn) newRootBtn.style.display = 'flex';
      if (treeRoot) treeRoot.style.display = 'block';
      toggleBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>';
    }
  });
</script>
