---
import { useTranslations } from '../../i18n/ui';
const lang = Astro.locals.lang || 'en';
const t = useTranslations(lang);
---
<footer class="mt-auto shrink-0 w-full relative overflow-hidden bg-forge-bg border-t border-forge-border">
  <!-- Subtle decorative gradient at the top of the footer -->
  <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-forge-primary/30 to-transparent"></div>
  <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-forge-secondary/5 rounded-full blur-[100px] -translate-y-1/2 translate-x-1/3 pointer-events-none"></div>

  <div class="max-w-[1440px] mx-auto px-6 py-16 relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-10 lg:gap-12 mb-16">
      <div class="col-span-1 md:col-span-2">
        <a href="/" class="inline-flex items-center gap-3 mb-6 group cursor-pointer">
          <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-forge-secondary to-forge-primary flex items-center justify-center font-black text-white text-lg shadow-[0_0_15px_rgba(255,93,0,0.3)] group-hover:scale-105 group-hover:shadow-[0_0_20px_rgba(255,93,0,0.5)] transition-all">
            F
          </div>
          <span class="text-2xl font-black text-forge-text tracking-tight group-hover:text-forge-secondary transition-colors">Forge</span>
        </a>
        <p class="text-sm text-forge-muted leading-relaxed max-w-sm">
          {t('footer.description')}
        </p>
      </div>
      
      <div class="col-span-1">
        <h3 class="font-bold text-forge-text mb-6 uppercase tracking-wider text-xs">{t('footer.product')}</h3>
        <ul class="space-y-4">
          <li><a href="/" class="text-sm text-forge-muted hover:text-forge-secondary hover:translate-x-1 inline-block transition-all">{t('footer.product.kanban')}</a></li>
          <li><a href="/" class="text-sm text-forge-muted hover:text-forge-secondary hover:translate-x-1 inline-block transition-all">{t('footer.product.kb')}</a></li>
          <li><a href="/" class="text-sm text-forge-muted hover:text-forge-secondary hover:translate-x-1 inline-block transition-all">{t('footer.product.chat')}</a></li>
          <li><a href="/" class="text-sm text-forge-muted hover:text-forge-secondary hover:translate-x-1 inline-block transition-all">{t('footer.product.db')}</a></li>
        </ul>
      </div>

      <div class="col-span-1">
        <h3 class="font-bold text-forge-text mb-6 uppercase tracking-wider text-xs">{t('footer.resources')}</h3>
        <ul class="space-y-4">
          <li><button onclick="document.getElementById('docs-modal')?.showModal() || window.showToast('Documentation unavailable', true)" class="text-sm text-forge-muted hover:text-forge-secondary hover:translate-x-1 inline-block transition-all text-left">{t('footer.resources.docs')}</button></li>
          <li><a href="https://github.com/JoseSerpaCode/Forge-js/commits/main" target="_blank" class="text-sm text-forge-muted hover:text-forge-secondary hover:translate-x-1 inline-block transition-all">{t('footer.resources.changelog')}</a></li>
          <li><button onclick="window.showToast('All systems operational.', false)" class="text-sm text-forge-muted hover:text-forge-secondary hover:translate-x-1 inline-block transition-all text-left flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-forge-success inline-block"></span>{t('footer.resources.status')}</button></li>
        </ul>
      </div>

      <div class="col-span-1">
        <h3 class="font-bold text-forge-text mb-6 uppercase tracking-wider text-xs">{t('footer.legal')}</h3>
        <ul class="space-y-4">
          <li><a href="#" class="text-sm text-forge-muted hover:text-forge-secondary hover:translate-x-1 inline-block transition-all">{t('footer.legal.privacy')}</a></li>
          <li><a href="#" class="text-sm text-forge-muted hover:text-forge-secondary hover:translate-x-1 inline-block transition-all">{t('footer.legal.terms')}</a></li>
          <li><a href="#" class="text-sm text-forge-muted hover:text-forge-secondary hover:translate-x-1 inline-block transition-all">{t('footer.legal.security')}</a></li>
        </ul>
      </div>
    </div>
    
    <div class="pt-8 border-t border-forge-border/40 flex flex-col md:flex-row items-center justify-between gap-6">
      <p class="text-xs text-forge-muted/70 font-medium">
        {t('footer.built_by')}
      </p>
      <div class="flex items-center gap-5">
        <a href="https://github.com/JoseSerpaCode/Forge-js" target="_blank" class="text-forge-muted hover:text-forge-secondary transition-colors" title="GitHub Repository">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
        </a>
        <a href="mailto:joseserpamedinaxd@gmail.com" class="text-forge-muted hover:text-forge-secondary transition-colors" title="Contact Email">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        </a>
      </div>
    </div>
  </div>
</footer>
