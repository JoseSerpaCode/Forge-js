---
import { useTranslations } from '../../i18n/ui';
const lang = Astro.locals.lang || 'en';
const t = useTranslations(lang);
---
<footer class="border-t border-forge-border/50 bg-forge-bg mt-auto shrink-0 w-full">
  <div class="max-w-[1440px] mx-auto px-6 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 lg:gap-12 mb-12">
      <div class="col-span-1 md:col-span-1">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-8 h-8 rounded-lg bg-forge-primary flex items-center justify-center font-black text-white text-sm shadow-md">
            F
          </div>
          <span class="text-xl font-bold text-forge-text tracking-tight">Forge</span>
        </div>
        <p class="text-sm text-forge-muted leading-relaxed">
          Kanban, wiki, chat and databases, in one workspace.
        </p>
      </div>
      
      <div class="col-span-1">
        <h3 class="font-bold text-forge-text mb-4">Product</h3>
        <ul class="space-y-3">
          <li><a href="#" class="text-sm text-forge-muted hover:text-forge-secondary transition-colors">Kanban boards</a></li>
          <li><a href="#" class="text-sm text-forge-muted hover:text-forge-secondary transition-colors">Knowledge base</a></li>
          <li><a href="#" class="text-sm text-forge-muted hover:text-forge-secondary transition-colors">Team chat</a></li>
          <li><a href="#" class="text-sm text-forge-muted hover:text-forge-secondary transition-colors">Databases</a></li>
        </ul>
      </div>

      <div class="col-span-1">
        <h3 class="font-bold text-forge-text mb-4">Resources</h3>
        <ul class="space-y-3">
          <li><a href="#" class="text-sm text-forge-muted hover:text-forge-secondary transition-colors">Documentation</a></li>
          <li><a href="#" class="text-sm text-forge-muted hover:text-forge-secondary transition-colors">Changelog</a></li>
          <li><a href="#" class="text-sm text-forge-muted hover:text-forge-secondary transition-colors">Status</a></li>
        </ul>
      </div>

      <div class="col-span-1">
        <h3 class="font-bold text-forge-text mb-4">Legal</h3>
        <ul class="space-y-3">
          <li><a href="#" class="text-sm text-forge-muted hover:text-forge-secondary transition-colors">Privacy policy</a></li>
          <li><a href="#" class="text-sm text-forge-muted hover:text-forge-secondary transition-colors">Terms of service</a></li>
          <li><a href="#" class="text-sm text-forge-muted hover:text-forge-secondary transition-colors">Security</a></li>
        </ul>
      </div>
    </div>
    
    <div class="pt-8 border-t border-forge-border/50 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-xs text-forge-muted">
        © 2026 Forge. Built by JoseSerpaCode.
      </p>
      <div class="flex items-center gap-4">
        <a href="https://github.com/JoseSerpaCode/Forge-js" target="_blank" class="text-forge-muted hover:text-forge-text transition-colors" title="GitHub">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
        </a>
        <a href="#" class="text-forge-muted hover:text-forge-text transition-colors" title="Email">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        </a>
      </div>
    </div>
  </div>
</footer>
