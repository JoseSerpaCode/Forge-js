---
import { useTranslations } from '../../i18n/ui';
const lang = Astro.locals.lang || 'en';
const t = useTranslations(lang);
---
<footer class="mt-auto shrink-0 w-full bg-forge-bg border-t border-forge-border/40">
  <div class="max-w-[1440px] mx-auto px-6 py-12">
    <div class="flex flex-col lg:flex-row justify-between gap-12 mb-12">
      <div class="lg:max-w-xs">
        <a href="/" class="inline-flex items-center gap-3 mb-4 group cursor-pointer">
          <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-forge-secondary to-forge-primary flex items-center justify-center font-black text-white text-lg shadow-[0_0_15px_rgba(255,93,0,0.3)] group-hover:scale-105 group-hover:shadow-[0_0_20px_rgba(255,93,0,0.5)] transition-all">
            F
          </div>
          <span class="text-2xl font-black text-forge-text tracking-tight group-hover:text-forge-secondary transition-colors">Forge</span>
        </a>
        <p class="text-sm text-forge-muted/80 leading-relaxed">
          {t('footer.description')}
        </p>
      </div>
      
      <div class="grid grid-cols-2 md:grid-cols-3 gap-8 lg:gap-16 w-full lg:w-auto">
        <div class="col-span-1">
          <h3 class="font-medium text-forge-text mb-4 text-sm">{t('footer.product')}</h3>
          <ul class="space-y-3">
            <li><a href="#" onclick="event.preventDefault(); window.showToast('Available inside your workspaces', false)" class="text-sm text-forge-muted/70 hover:text-forge-text transition-colors">{t('footer.product.kanban')}</a></li>
            <li><a href="#" onclick="event.preventDefault(); window.showToast('Available inside your workspaces', false)" class="text-sm text-forge-muted/70 hover:text-forge-text transition-colors">{t('footer.product.kb')}</a></li>
            <li><a href="#" onclick="event.preventDefault(); window.showToast('Feature in development', false)" class="text-sm text-forge-muted/70 hover:text-forge-text transition-colors">{t('footer.product.chat')}</a></li>
            <li><a href="#" onclick="event.preventDefault(); window.showToast('Available inside your workspaces', false)" class="text-sm text-forge-muted/70 hover:text-forge-text transition-colors">{t('footer.product.db')}</a></li>
          </ul>
        </div>

        <div class="col-span-1">
          <h3 class="font-medium text-forge-text mb-4 text-sm">{t('footer.resources')}</h3>
          <ul class="space-y-3">
            <li><button onclick="document.getElementById('docs-modal')?.showModal() || window.showToast('Documentation unavailable', true)" class="text-sm text-forge-muted/70 hover:text-forge-text transition-colors text-left">{t('footer.resources.docs')}</button></li>
            <li><a href="https://github.com/JoseSerpaCode/Forge-js/commits/main" target="_blank" class="text-sm text-forge-muted/70 hover:text-forge-text transition-colors">{t('footer.resources.changelog')}</a></li>
          </ul>
        </div>

        <div class="col-span-2 md:col-span-1">
          <h3 class="font-medium text-forge-text mb-4 text-sm">{t('footer.legal')}</h3>
          <ul class="space-y-3">
            <li><a href="#" class="text-sm text-forge-muted/70 hover:text-forge-text transition-colors">{t('footer.legal.privacy')}</a></li>
            <li><a href="#" class="text-sm text-forge-muted/70 hover:text-forge-text transition-colors">{t('footer.legal.terms')}</a></li>
            <li><a href="#" class="text-sm text-forge-muted/70 hover:text-forge-text transition-colors">{t('footer.legal.security')}</a></li>
          </ul>
        </div>
      </div>
    </div>
    
    <div class="pt-8 border-t border-forge-border/30 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-sm text-forge-muted/60">
        {t('footer.built_by')}
      </p>
      <div class="flex items-center gap-4">
        <a href="https://github.com/JoseSerpaCode/Forge-js" target="_blank" class="text-forge-muted/60 hover:text-forge-text transition-colors" title="GitHub Repository">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
        </a>
        <a href="mailto:joseserpamedinaxd@gmail.com" class="text-forge-muted/60 hover:text-forge-text transition-colors" title="Contact Email">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        </a>
      </div>
    </div>
  </div>
</footer>
