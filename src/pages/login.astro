---
// src/pages/login.astro
import '../styles/themes.css';

const user = Astro.locals.user;
if (user) return Astro.redirect('/');
---
<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <title>Login | Forge JS</title>
</head>
<body class="bg-forge-bg text-white font-sans h-screen flex flex-col items-center justify-center">
  <div class="bg-forge-panel border border-forge-border p-8 rounded-lg w-96">
    <div class="text-center mb-8">
      <div class="w-16 h-16 rounded-2xl bg-forge-primary mx-auto mb-6 flex items-center justify-center">
        <span class="text-3xl font-black text-white">F</span>
      </div>
      <h1 class="text-2xl font-black tracking-wider text-forge-text mb-2">FORGE OS</h1>
      <p class="text-forge-muted text-sm font-mono">AUTHORIZED PERSONNEL ONLY</p>
    </div>
    <form id="login-form" class="flex flex-col gap-4">
      <div>
        <label class="block text-xs font-mono text-forge-text mb-1 uppercase">Username</label>
        <input type="text" name="username" class="w-full bg-forge-bg border border-forge-border p-2 rounded text-forge-text focus:outline-none focus:border-forge-secondary" required />
      </div>
      <div class="mb-6">
        <label class="block text-sm font-bold text-forge-muted uppercase tracking-widest mb-1">Password</label>
        <input type="password" name="password" class="w-full bg-forge-bg border border-forge-border p-2 rounded text-forge-text focus:outline-none focus:border-forge-secondary" required />
      </div>
      <button type="submit" class="mt-4 bg-forge-primary text-forge-bg font-bold uppercase tracking-widest py-2 rounded hover:bg-forge-primary/80 transition-colors">Submit</button>
      <p id="error-msg" class="text-red-500 text-sm mt-2 hidden"></p>
    </form>
    
    <div class="mt-6 text-center">
      <a href="/register" class="text-forge-secondary text-sm hover:underline">Don't have an account? Register</a>
    </div>
  </div>

  <script>
    document.getElementById('login-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const fd = new FormData(e.target as HTMLFormElement);
      const res = await fetch('/api/auth/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(Object.fromEntries(fd))
      });
      if (res.ok) {
        window.location.href = '/';
      } else {
        const errorMsg = document.getElementById('error-msg');
        if (errorMsg) {
          errorMsg.textContent = 'Invalid credentials';
          errorMsg.classList.remove('hidden');
        }
      }
    });
  </script>
</body>
</html>
