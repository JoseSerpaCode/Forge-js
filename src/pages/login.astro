---
// src/pages/login.astro
import '../styles/themes.css';

const user = Astro.locals.user;
if (user) return Astro.redirect('/');
---
<!DOCTYPE html>
<html lang="es" data-theme="orion_neon">
<head>
  <meta charset="UTF-8">
  <title>Login | Forge JS</title>
</head>
<body class="bg-forge-bg text-forge-text font-sans h-screen flex flex-col items-center justify-center">
  <div class="bg-forge-panel border border-forge-border p-8 rounded-lg shadow-xl w-96">
    <h1 class="text-2xl font-bold text-forge-neon mb-6">System Login</h1>
    <form id="login-form" class="flex flex-col gap-4">
      <div>
        <label class="block text-xs font-mono text-forge-text mb-1 uppercase">Username</label>
        <input type="text" name="username" class="w-full bg-forge-bg border border-forge-border p-2 rounded text-white focus:outline-none focus:border-forge-neon" required />
      </div>
      <div>
        <label class="block text-xs font-mono text-forge-text mb-1 uppercase">Password</label>
        <input type="password" name="password" class="w-full bg-forge-bg border border-forge-border p-2 rounded text-white focus:outline-none focus:border-forge-neon" required />
      </div>
      <button type="submit" class="mt-4 bg-forge-neon text-black font-bold uppercase tracking-widest py-2 rounded hover:bg-forge-neon/80 transition-colors">Submit</button>
      <p id="error-msg" class="text-red-500 text-sm mt-2 hidden"></p>
    </form>
  </div>

  <script>
    document.getElementById('login-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const fd = new FormData(e.target as HTMLFormElement);
      const res = await fetch('/api/auth/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(Object.fromEntries(fd))
      });
      if (res.ok) {
        window.location.href = '/';
      } else {
        const errorMsg = document.getElementById('error-msg');
        if (errorMsg) {
          errorMsg.textContent = 'Invalid credentials';
          errorMsg.classList.remove('hidden');
        }
      }
    });
  </script>
</body>
</html>
