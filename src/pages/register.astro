---
import '../styles/themes.css';

import { useTranslations } from '../i18n/ui';
const user = Astro.locals.user;
if (user && !user.is_guest) return Astro.redirect('/');
const lang = Astro.locals.lang || 'en';
const t = useTranslations(lang);
---
<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=5" />
  <meta name="description" content="Register a new Forge OS account." />
  <title>Register | Forge JS</title>
</head>
<body class="bg-forge-bg text-forge-text font-sans h-screen flex flex-col items-center justify-center">
  <div class="bg-forge-panel border border-forge-border p-8 rounded-lg w-96">
    <div class="text-center mb-8">
      <div class="w-16 h-16 rounded-2xl bg-forge-primary mx-auto mb-6 flex items-center justify-center">
        <span class="text-3xl font-black text-white">F</span>
      </div>
      <h1 class="text-2xl font-black tracking-wider text-forge-text mb-2">FORGE OS</h1>
      <p class="text-forge-muted text-sm font-mono">{t('auth.new_personnel')}</p>
    </div>
    <form id="register-form" class="flex flex-col gap-4">
      <div>
        <label for="username" class="block text-xs font-mono text-forge-text mb-1 uppercase">{t('auth.username')}</label>
        <input type="text" id="username" name="username" class="w-full bg-forge-bg border border-forge-border p-2 rounded text-forge-text focus:outline-none focus:border-forge-secondary" required minlength="3" />
      </div>
      <div>
        <label for="password" class="block text-sm font-bold text-forge-muted uppercase tracking-widest mb-1">{t('auth.password')}</label>
        <input type="password" id="password" name="password" class="w-full bg-forge-bg border border-forge-border p-2 rounded text-forge-text focus:outline-none focus:border-forge-secondary" required minlength="6" />
      </div>
      <button type="submit" class="mt-4 bg-forge-primary text-forge-bg font-bold uppercase tracking-widest py-2 rounded hover:bg-forge-primary/80 transition-colors">{t('auth.signup')}</button>
      <p id="error-msg" class="text-red-500 text-sm mt-2 hidden"></p>
    </form>
    
    <div class="mt-6 text-center">
      <a href="/login" class="text-forge-secondary text-sm hover:underline">{t('auth.have_account')}</a>
    </div>
  </div>

  <script>
    document.getElementById('register-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const fd = new FormData(e.target as HTMLFormElement);
      const res = await fetch('/api/auth/register', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(Object.fromEntries(fd))
      });
      
      if (res.ok) {
        window.location.href = '/';
      } else {
        const data = await res.json().catch(() => ({}));
        const errorMsg = document.getElementById('error-msg');
        if (errorMsg) {
          errorMsg.textContent = data.error || 'Registration failed';
          errorMsg.classList.remove('hidden');
        }
      }
    });
  </script>
</body>
</html>
