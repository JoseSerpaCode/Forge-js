---
// src/pages/w/[sys_tag]/index.astro — Redesigned Dashboard
import MainLayout from '../../../layouts/MainLayout.astro';
import db from '../../../lib/db';
import { checkWorkspaceAccess } from '../../../lib/guard';

const { sys_tag } = Astro.params;
const user = Astro.locals.user;

if (!user) return Astro.redirect('/login');

import { useTranslations } from '../../../i18n/ui';
const lang = Astro.locals.lang || 'en';
const t = useTranslations(lang);

const workspace = db.prepare('SELECT id, name, icon, description FROM workspaces WHERE sys_tag = ?').get(sys_tag) as any;
if (!workspace) return Astro.redirect('/404');

const access = checkWorkspaceAccess(user.id, user.is_sysadmin, workspace.id, 'viewer');
if (!access.granted) return new Response('Access Denied', { status: 403 });

// ──── Stats ────
const activeSprints = db.prepare(`
  SELECT id, name, start_date, end_date, goal 
  FROM sprints WHERE workspace_id = ? AND status = 'active' 
  ORDER BY start_date ASC
`).all(workspace.id) as any[];

const urlSprintId = Astro.url.searchParams.get('sprint');
let activeSprint = activeSprints.find(s => s.id === urlSprintId);
if (!activeSprint && activeSprints.length > 0) {
  activeSprint = activeSprints[0];
}

let pendingIssues = { count: 0 };
let blockedIssues = { count: 0 };
let sprintProgress = 0;
let sprintDaysLeft = 0;

if (activeSprint) {
  pendingIssues = db.prepare(`
    SELECT COUNT(*) as count FROM issues 
    WHERE workspace_id = ? AND sprint_id = ? AND status != 'done'
  `).get(workspace.id, activeSprint.id) as any;

  blockedIssues = db.prepare(`
    SELECT COUNT(*) as count FROM issues 
    WHERE workspace_id = ? AND sprint_id = ? AND status = 'blocked'
  `).get(workspace.id, activeSprint.id) as any;

  const doneInSprint = db.prepare(`
    SELECT COUNT(*) as count FROM issues WHERE sprint_id = ? AND status = 'done'
  `).get(activeSprint.id) as any;
  const totalInSprint = db.prepare(`
    SELECT COUNT(*) as count FROM issues WHERE sprint_id = ?
  `).get(activeSprint.id) as any;
  
  sprintProgress = totalInSprint.count > 0 
    ? Math.round((doneInSprint.count / totalInSprint.count) * 100) 
    : 0;
  
  if (activeSprint.end_date) {
    const endDate = new Date(activeSprint.end_date);
    const now = new Date();
    sprintDaysLeft = Math.max(0, Math.ceil((endDate.getTime() - now.getTime()) / (1000 * 60 * 60 * 24)));
  }
} else {
  pendingIssues = db.prepare(`
    SELECT COUNT(*) as count FROM issues 
    WHERE workspace_id = ? AND status != 'done'
  `).get(workspace.id) as any;

  blockedIssues = db.prepare(`
    SELECT COUNT(*) as count FROM issues 
    WHERE workspace_id = ? AND status = 'blocked'
  `).get(workspace.id) as any;
}

const totalPages = db.prepare(`
  SELECT COUNT(*) as count FROM pages WHERE workspace_id = ?
`).get(workspace.id) as any;

// ──── Roadmap (All sprints) ────
const allSprints = db.prepare(`
  SELECT id, name, start_date, end_date, status, goal
  FROM sprints WHERE workspace_id = ?
  ORDER BY COALESCE(start_date, '9999') ASC
  LIMIT 6
`).all(workspace.id) as any[];

// ──── Milestones ────
const milestones = db.prepare(`
  SELECT id, name, target_date, status 
  FROM milestones WHERE workspace_id = ? AND status = 'planned'
  ORDER BY target_date ASC LIMIT 3
`).all(workspace.id) as any[];

// ──── Recent activity (audit log) ────
const recentActivity = db.prepare(`
  SELECT al.action, al.entity_type, al.entity_id, al.details_json, al.timestamp,
         u.username, u.avatar_url
  FROM audit_logs al
  LEFT JOIN users u ON al.user_id = u.id
  WHERE al.entity_id IN (
    SELECT id FROM issues WHERE workspace_id = ?
    UNION SELECT id FROM pages WHERE workspace_id = ?
  )
  ORDER BY al.timestamp DESC LIMIT 8
`).all(workspace.id, workspace.id) as any[];

// ──── Workload per member ────
const members = db.prepare(`
  SELECT u.id, u.username, u.avatar_url
  FROM workspace_members wm JOIN users u ON wm.user_id = u.id
  WHERE wm.workspace_id = ?
  ORDER BY u.username ASC LIMIT 6
`).all(workspace.id) as any[];

for (const member of members) {
  const openIssues = db.prepare(`
    SELECT COUNT(*) as count FROM issues 
    WHERE workspace_id = ? AND assignee_id = ? AND status != 'done'
  `).get(workspace.id, member.id) as any;
  member.openCount = openIssues.count;
}
const maxWorkload = Math.max(...members.map((m: any) => m.openCount), 1);

// ──── My tasks in this workspace ────
const myTasks = db.prepare(`
  SELECT i.id, i.title, i.status, i.priority, i.sprint_id 
  FROM issues i
  WHERE i.workspace_id = ? ${activeSprint ? "AND i.sprint_id = '" + activeSprint.id + "'" : ''} AND i.status != 'done' AND i.assignee_id = ?
  ORDER BY 
    CASE i.priority WHEN 'highest' THEN 1 WHEN 'high' THEN 2 WHEN 'medium' THEN 3 WHEN 'low' THEN 4 ELSE 5 END ASC
  LIMIT 5
`).all(workspace.id, user.id) as any[];

// Date formatting helpers passed to template
const formatDate = (dateStr: string | null) => {
  if (!dateStr) return '';
  const d = new Date(dateStr.includes('T') ? dateStr : dateStr.replace(' ', 'T') + 'Z');
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
};

const formatRelative = (dateStr: string) => {
  const d = new Date(dateStr.includes('T') ? dateStr : dateStr.replace(' ', 'T') + 'Z');
  const diff = Date.now() - d.getTime();
  const mins = Math.floor(diff / 60000);
  if (mins < 60) return `${mins}m ago`;
  const hours = Math.floor(mins / 60);
  if (hours < 24) return `${hours}h ago`;
  return `${Math.floor(hours / 24)}d ago`;
};

const actionLabel = (action: string) => {
  const map: Record<string, string> = {
    ISSUE_MOVED: 'moved issue',
    ISSUE_CREATED: 'created issue',
    ISSUE_UPDATED: 'updated issue',
    PAGE_UPDATED: 'edited page',
    PAGE_CREATED: 'created page',
  };
  return map[action] || action.toLowerCase().replace('_', ' ');
};

const statusColor: Record<string, string> = {
  todo: 'bg-forge-muted/20 text-forge-muted',
  'in-progress': 'bg-blue-500/20 text-blue-400',
  'in_progress': 'bg-blue-500/20 text-blue-400',
  review: 'bg-yellow-500/20 text-yellow-400',
  done: 'bg-green-500/20 text-green-400',
  blocked: 'bg-red-500/20 text-red-400',
};
const priorityColor: Record<string, string> = {
  highest: 'text-red-400',
  high: 'text-orange-400',
  medium: 'text-yellow-400',
  low: 'text-blue-400',
  lowest: 'text-forge-muted',
};
---

<MainLayout title={`${t('sidebar.dashboard')} — ${workspace.name}`} workspaceId={workspace.id}>
  <div class="space-y-6 max-w-[1400px]">
    
    <!-- Header -->
    <header class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold text-forge-text">{workspace.name}</h1>
        <p class="text-sm text-forge-muted mt-0.5">{t('sidebar.dashboard')} — workspace overview</p>
      </div>
      <div class="flex gap-2">
        <a href={`/w/${sys_tag}/board`} class="flex items-center gap-2 text-xs font-bold px-3 py-2 rounded bg-forge-secondary text-forge-bg hover:opacity-90 transition-opacity">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="3" width="7" height="9"/><rect x="14" y="3" width="7" height="5"/><rect x="14" y="12" width="7" height="9"/><rect x="3" y="16" width="7" height="5"/></svg>
          {t('dashboard.open_board')}
        </a>
        <a href={`/w/${sys_tag}/p`} class="flex items-center gap-2 text-xs font-bold px-3 py-2 rounded bg-forge-panel border border-forge-border text-forge-text hover:border-forge-secondary transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/></svg>
          {t('dashboard.knowledge_base')}
        </a>
      </div>
    </header>

    <!-- Stats Row -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <!-- Sprint activo -->
      <div class="bg-forge-panel border border-forge-border rounded-xl p-4 hover:border-forge-secondary/50 transition-colors group">
        <div class="flex items-center justify-between mb-3">
          <span class="text-xs font-bold text-forge-muted uppercase tracking-wider">{t('dashboard.active_sprint')}</span>
          {activeSprints.length > 1 ? (
             <form id="sprint-selector-form" method="get">
               <select name="sprint" onchange="this.form.submit()" class="bg-forge-bg border border-forge-border text-xs rounded p-1 text-forge-text focus:outline-none focus:border-forge-secondary">
                 {activeSprints.map(s => <option value={s.id} selected={activeSprint?.id === s.id}>{s.name}</option>)}
               </select>
             </form>
          ) : (
             <div class={`w-2 h-2 rounded-full ${activeSprint ? 'bg-forge-secondary animate-pulse' : 'bg-forge-muted'}`}></div>
          )}
        </div>
        {activeSprint ? (
          <>
            <div class="text-xl font-black text-forge-text mb-1 truncate">{activeSprint.name}</div>
            <div class="flex items-center gap-2 mb-2">
              <div class="flex-1 h-1 bg-forge-bg rounded-full overflow-hidden">
                <div class="h-full bg-forge-secondary rounded-full transition-all" style={`width: ${sprintProgress}%`}></div>
              </div>
              <span class="text-[10px] font-mono text-forge-muted shrink-0">{sprintProgress}%</span>
            </div>
            <span class="text-xs text-forge-muted">
              {sprintDaysLeft > 0 ? t('dashboard.ends_in').replace('{days}', String(sprintDaysLeft)) : t('dashboard.ending_today')}
            </span>
          </>
        ) : (
          <div class="mt-1">
            <div class="text-forge-muted text-sm">{t('dashboard.no_active_sprint')}</div>
            <a href={`/w/${sys_tag}/board`} class="text-xs text-forge-secondary hover:underline mt-1 inline-block">{t('dashboard.new_sprint')}</a>
          </div>
        )}
      </div>

      <!-- Issues pendientes -->
      <a href={`/w/${sys_tag}/board${activeSprint ? `?sprint=${activeSprint.id}` : ''}`} class="bg-forge-panel border border-forge-border rounded-xl p-4 hover:border-forge-secondary/50 transition-colors group block">
        <div class="flex items-center justify-between mb-3">
          <span class="text-xs font-bold text-forge-muted uppercase tracking-wider">{t('dashboard.pending_issues')}</span>
          <svg class="text-forge-muted group-hover:text-forge-secondary transition-colors" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        </div>
        <div class="text-4xl font-black text-forge-secondary">{pendingIssues.count}</div>
        {blockedIssues.count > 0 && (
          <div class="text-xs text-red-400 mt-1 font-medium">{t('dashboard.blocked').replace('{count}', String(blockedIssues.count))}</div>
        )}
      </a>

      <!-- KB Pages -->
      <a href={`/w/${sys_tag}/p`} class="bg-forge-panel border border-forge-border rounded-xl p-4 hover:border-forge-secondary/50 transition-colors group block">
        <div class="flex items-center justify-between mb-3">
          <span class="text-xs font-bold text-forge-muted uppercase tracking-wider">{t('dashboard.kb_pages')}</span>
          <svg class="text-forge-muted group-hover:text-forge-secondary transition-colors" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/></svg>
        </div>
        <div class="text-4xl font-black text-forge-text">{totalPages.count}</div>
        <div class="text-xs text-forge-muted mt-1">{t('dashboard.knowledge_articles')}</div>
      </a>
    </div>

    <!-- Middle Row: Roadmap -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      
      <!-- Roadmap -->
      <div class="lg:col-span-2 bg-forge-panel border border-forge-border rounded-xl p-5">
        <div class="flex items-center justify-between mb-4">
          <h2 class="font-bold text-forge-text flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-forge-secondary"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
            {t('dashboard.roadmap')}
          </h2>
          <a href={`/w/${sys_tag}/board`} class="text-xs text-forge-muted hover:text-forge-secondary transition-colors">{t('dashboard.view_board')}</a>
        </div>

        {allSprints.length === 0 ? (
          <div class="py-8 text-center text-forge-muted text-sm">
            <p>{t('dashboard.no_sprints')}</p>
            <a href={`/w/${sys_tag}/board`} class="text-forge-secondary hover:underline text-xs mt-2 inline-block">{t('dashboard.create_sprint')}</a>
          </div>
        ) : (
          <div class="space-y-3" id="roadmap-container">
            {allSprints.map((sprint, i) => {
              // Calculate bar widths relative to first sprint start and last sprint end
              const firstStart = allSprints.find(s => s.start_date)?.start_date;
              const lastEnd = [...allSprints].reverse().find(s => s.end_date)?.end_date;
              
              let barLeft = 0;
              let barWidth = 50; // default
              
              if (firstStart && lastEnd && sprint.start_date && sprint.end_date) {
                const rangeStart = new Date(firstStart).getTime();
                const rangeEnd = new Date(lastEnd).getTime();
                const range = rangeEnd - rangeStart || 1;
                const sprintStart = new Date(sprint.start_date).getTime();
                const sprintEnd = new Date(sprint.end_date).getTime();
                barLeft = Math.max(0, Math.min(100, ((sprintStart - rangeStart) / range) * 100));
                barWidth = Math.max(8, Math.min(100 - barLeft, ((sprintEnd - sprintStart) / range) * 100));
              } else {
                barLeft = (i / Math.max(allSprints.length, 3)) * 60;
                barWidth = 100 / Math.max(allSprints.length, 3) * 0.8;
              }

              const barColor = sprint.status === 'completed' ? 'bg-forge-muted/40' : 
                               sprint.status === 'active' ? 'bg-forge-secondary' : 
                               'bg-forge-secondary/30';
              
              return (
                <div class="flex items-center gap-3">
                  <span class="text-xs text-forge-muted font-mono w-20 shrink-0 truncate" title={sprint.name}>{sprint.name}</span>
                  <div class="flex-1 h-4 bg-forge-bg rounded-full relative overflow-hidden border border-forge-border/30">
                    <div 
                      class={`absolute h-full rounded-full ${barColor} transition-all duration-700`}
                      style={`left: ${barLeft}%; width: ${barWidth}%`}
                    ></div>
                    {sprint.status === 'active' && (
                      <div class="absolute inset-0 flex items-center justify-center">
                        <span class="text-[9px] font-bold text-forge-bg/90 z-10">{sprintProgress}%</span>
                      </div>
                    )}
                  </div>
                  <div class="flex items-center gap-1 shrink-0">
                    {sprint.end_date && (
                      <span class="text-[10px] text-forge-muted font-mono w-16 text-right">{formatDate(sprint.end_date)}</span>
                    )}
                    <span class={`text-[9px] font-bold px-1.5 py-0.5 rounded-full ${
                      sprint.status === 'completed' ? 'bg-forge-muted/20 text-forge-muted' :
                      sprint.status === 'active' ? 'bg-forge-secondary/20 text-forge-secondary' :
                      'bg-forge-panel text-forge-muted border border-forge-border'
                    }`}>{sprint.status}</span>
                  </div>
                </div>
              );
            })}

            {milestones.map(m => (
              <div class="flex items-center gap-3 pt-1 border-t border-forge-border/30 mt-1">
                <span class="text-xs text-yellow-400/80 font-mono w-20 shrink-0 flex items-center gap-1">
                  <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/></svg>
                  {m.name}
                </span>
                <div class="flex-1 border-t border-dashed border-yellow-400/20"></div>
                <span class="text-[10px] font-mono text-yellow-400/70 shrink-0">{formatDate(m.target_date)}</span>
              </div>
            ))}
          </div>
        )}
      </div>

      <!-- My Tasks -->
      <div class="bg-forge-panel border border-forge-border rounded-xl p-5">
        <h2 class="font-bold text-forge-text flex items-center gap-2 mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-forge-secondary"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
          {t('dashboard.my_tasks')}
        </h2>
        {myTasks.length === 0 ? (
          <div class="text-sm text-forge-muted text-center py-6">
            <p>{t('dashboard.no_tasks')}</p>
            <p class="text-xs mt-1">{t('dashboard.all_caught_up')}</p>
          </div>
        ) : (
          <div class="space-y-2">
            {myTasks.map(task => (
              <a 
                href={`/w/${sys_tag}/board?sprint=${task.sprint_id || 'backlog'}&issue=${task.id}`}
                class="flex items-center gap-2 p-2 rounded hover:bg-forge-bg transition-colors group"
              >
                <span class={`text-[10px] font-bold shrink-0 ${priorityColor[task.priority] || 'text-forge-muted'}`} title={task.priority}>
                  {task.priority === 'highest' ? '▲▲' : task.priority === 'high' ? '▲' : task.priority === 'low' ? '▼' : task.priority === 'lowest' ? '▼▼' : '●'}
                </span>
                <span class="text-xs text-forge-text group-hover:text-forge-secondary transition-colors flex-1 truncate">{task.title}</span>
                <span class={`text-[9px] font-bold px-1.5 py-0.5 rounded-full shrink-0 ${statusColor[task.status] || 'bg-forge-muted/20 text-forge-muted'}`}>
                  {task.status.replace('_', ' ').replace('-', ' ')}
                </span>
              </a>
            ))}
            <a href={`/w/${sys_tag}/board`} class="block text-center text-xs text-forge-muted hover:text-forge-secondary transition-colors pt-2 border-t border-forge-border mt-2">
              {t('dashboard.view_all_board')}
            </a>
          </div>
        )}
      </div>
    </div>

    <!-- Bottom Row: Activity + Workload -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      
      <!-- Recent Activity -->
      <div class="bg-forge-panel border border-forge-border rounded-xl p-5">
        <h2 class="font-bold text-forge-text flex items-center gap-2 mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-forge-secondary"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          {t('dashboard.recent_activity')}
        </h2>
        {recentActivity.length === 0 ? (
          <div class="text-sm text-forge-muted text-center py-6">{t('dashboard.no_activity')}</div>
        ) : (
          <div class="space-y-3">
            {recentActivity.map(act => (
              <div class="flex items-start gap-2.5">
                <img 
                  src={act.avatar_url || '/default-avatar.svg'} 
                  class="w-6 h-6 rounded-full border border-forge-border bg-forge-bg shrink-0 mt-0.5" 
                  alt={act.username}
                />
                <div class="flex-1 min-w-0">
                  <p class="text-xs text-forge-text">
                    <span class="font-bold">{act.username || 'System'}</span>
                    {' '}<span class="text-forge-muted">{actionLabel(act.action)}</span>
                  </p>
                  <p class="text-[10px] text-forge-muted mt-0.5">{formatRelative(act.timestamp)}</p>
                </div>
              </div>
            ))}
          </div>
        )}
      </div>

      <!-- Workload -->
      <div class="bg-forge-panel border border-forge-border rounded-xl p-5">
        <h2 class="font-bold text-forge-text flex items-center gap-2 mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-forge-secondary"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="9" y1="3" x2="9" y2="21"/></svg>
          {t('dashboard.workload')}
        </h2>
        {members.length === 0 ? (
          <div class="text-sm text-forge-muted text-center py-6">{t('dashboard.no_members')}</div>
        ) : (
          <div class="space-y-3">
            {members.map((member: any) => (
              <div>
                <div class="flex items-center justify-between mb-1">
                  <div class="flex items-center gap-2">
                    <img src={member.avatar_url || '/default-avatar.svg'} class="w-5 h-5 rounded-full border border-forge-border" alt={member.username} />
                    <span class="text-xs font-medium text-forge-text truncate max-w-[100px]">{member.username}</span>
                  </div>
                  <span class="text-[10px] font-mono text-forge-muted">{member.openCount} {t('dashboard.open')}</span>
                </div>
                <div class="h-1.5 bg-forge-bg rounded-full overflow-hidden">
                  <div 
                    class={`h-full rounded-full transition-all duration-700 ${
                      member.openCount === 0 ? 'bg-forge-muted/20' :
                      member.openCount / maxWorkload > 0.75 ? 'bg-red-400' :
                      member.openCount / maxWorkload > 0.5 ? 'bg-yellow-400' :
                      'bg-forge-secondary'
                    }`}
                    style={`width: ${maxWorkload > 0 ? (member.openCount / maxWorkload) * 100 : 0}%`}
                  ></div>
                </div>
              </div>
            ))}
          </div>
        )}
      </div>

    </div>
  </div>

</MainLayout>
