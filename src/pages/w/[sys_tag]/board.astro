---
import MainLayout from '../../../layouts/MainLayout.astro';
import KanbanBoard from '../../../components/jira/KanbanBoard.astro';
import db from '../../../lib/db';
import { checkWorkspaceAccess } from '../../../lib/guard';
import { useTranslations } from '../../../i18n/ui';

const { sys_tag } = Astro.params;
const user = Astro.locals.user!;
const lang = Astro.locals.lang || 'en';
const t = useTranslations(lang);

if (!user) return Astro.redirect('/login');

const workspace = db.prepare('SELECT id, name FROM workspaces WHERE sys_tag = ?').get(sys_tag) as any;
if (!workspace) return Astro.redirect('/404');

const access = checkWorkspaceAccess(user.id, user.is_sysadmin, workspace.id, 'viewer');
if (!access.granted) return new Response('Access Denied', { status: 403 });

// Read sprint from URL
const requestedSprintId = Astro.url.searchParams.get('sprint');
let activeSprintId = null;
let currentSprintObj = null;

// IDOR Protection: Validate requested sprint belongs to this workspace
if (requestedSprintId && requestedSprintId !== 'backlog') {
  const sprintCheck = db.prepare('SELECT workspace_id, status FROM sprints WHERE id = ?').get(requestedSprintId) as any;
  if (!sprintCheck || sprintCheck.workspace_id !== workspace.id) {
    return new Response('Sprint Not Found', { status: 404 });
  }
  activeSprintId = requestedSprintId;
  currentSprintObj = sprintCheck;
}

// Fetch all sprints for the dropdown
const sprints = db.prepare('SELECT id, name, status FROM sprints WHERE workspace_id = ? ORDER BY start_date DESC, rowid DESC').all(workspace.id) as any[];

let issuesQuery = `
  SELECT i.*, 
         u1.username as reporter_username, 
         u1.avatar_url as reporter_avatar,
         u2.username as assignee_username,
         u2.avatar_url as assignee_avatar,
         (SELECT started_at FROM time_tracking_sessions WHERE issue_id = i.id AND user_id = ?) as active_session_start
  FROM issues i
  LEFT JOIN users u1 ON i.reporter_id = u1.id
  LEFT JOIN users u2 ON i.assignee_id = u2.id
  WHERE i.workspace_id = ?
`;
const queryParams: any[] = [user.id, workspace.id];

if (activeSprintId) {
  issuesQuery += ' AND i.sprint_id = ?';
  queryParams.push(activeSprintId);
} else {
  issuesQuery += ' AND i.sprint_id IS NULL';
}

issuesQuery += ' ORDER BY i.position ASC, i.id ASC';
const issues = db.prepare(issuesQuery).all(...queryParams) as any[];

const activeSprintName = activeSprintId ? sprints.find(s => s.id === activeSprintId)?.name : 'Backlog';

// Fetch workspace members for assignee/reporter dropdowns
const workspaceMembers = db.prepare(`
  SELECT u.id, u.username 
  FROM workspace_members wm 
  JOIN users u ON wm.user_id = u.id 
  WHERE wm.workspace_id = ?
`).all(workspace.id) as any[];

let totalLogged = 0;
let totalEstimated = 0;
if (activeSprintId) {
  const totals = db.prepare(`
    SELECT SUM(logged_hours) as total_logged, SUM(estimated_hours) as total_estimated
    FROM issues
    WHERE sprint_id = ?
  `).get(activeSprintId) as any;
  totalLogged = totals.total_logged || 0;
  totalEstimated = totals.total_estimated || 0;
}
---

<MainLayout title={`Board - ${workspace.name}`} workspaceId={workspace.id}>
  <div class="h-full flex flex-col">
    <header class="mb-4 flex flex-col xl:flex-row justify-between items-start xl:items-center gap-4">
      <div class="flex items-center gap-4">
        <h1 class="text-2xl font-bold text-forge-text">{workspace.name} Board</h1>
        {activeSprintId && (
          <div class="hidden md:flex flex-col w-32" id="sprint-time-container" data-logged={totalLogged} data-estimated={totalEstimated}>
            <div class="flex justify-between text-[10px] font-mono mb-1">
              <span class="text-forge-muted">Time</span>
              <span class="font-bold text-forge-secondary" id="sprint-time-text">{totalLogged}h / {totalEstimated > 0 ? totalEstimated + 'h' : '0h'}</span>
            </div>
            <div class="h-1.5 w-full bg-forge-bg rounded-full overflow-hidden border border-forge-border/30">
              <div id="sprint-time-bar" class={`h-full transition-all ${totalEstimated > 0 && (totalLogged / totalEstimated) > 1 ? 'bg-red-500' : 'bg-forge-secondary'}`} style={`width: ${totalEstimated > 0 ? Math.min((totalLogged / totalEstimated) * 100, 100) : 0}%`}></div>
            </div>
          </div>
        )}
      </div>

      <div class="flex flex-wrap gap-2 items-center w-full xl:w-auto">
        <select id="sprint-selector" class="bg-forge-bg text-forge-text border border-forge-border rounded-md px-3 py-1.5 text-sm focus:outline-none focus:border-forge-secondary">
          <option value="backlog" selected={!activeSprintId}>Backlog</option>
          {sprints.map(s => (
            <option value={s.id} selected={activeSprintId === s.id}>{s.name} {s.status === 'active' ? '(Active)' : s.status === 'completed' ? '(Completed)' : ''}</option>
          ))}
        </select>
        
        {access.role !== 'viewer' && activeSprintId && currentSprintObj && (
          <div class="flex items-center gap-1 bg-forge-bg rounded-md border border-forge-border/50 p-1">
            <button id="btn-toggle-sprint" data-sprint-id={activeSprintId} data-current-status={currentSprintObj.status} class={`font-bold px-3 py-1 rounded text-xs transition-colors ${currentSprintObj.status === 'planned' ? 'bg-forge-success text-white hover:opacity-90' : currentSprintObj.status === 'active' ? 'bg-forge-primary text-forge-bg hover:opacity-90' : 'bg-forge-secondary text-forge-bg hover:opacity-90'}`}>
              {currentSprintObj.status === 'planned' ? 'Start' : currentSprintObj.status === 'active' ? 'Complete' : 'Reopen'}
            </button>
            {currentSprintObj.status === 'active' && (
              <button id="btn-deactivate-sprint" data-sprint-id={activeSprintId} class="text-forge-muted hover:text-forge-error px-2 py-1 rounded transition-colors" title="Deactivate Sprint">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18.36 6.64a9 9 0 1 1-12.73 0"></path><line x1="12" y1="2" x2="12" y2="12"></line></svg>
              </button>
            )}
          </div>
        )}

        {(access.role === 'owner' || access.role === 'editor') && (
          <button id="btn-new-sprint" class="bg-forge-panel border border-forge-border hover:bg-forge-border/40 text-forge-text font-bold px-3 py-1.5 rounded-md text-sm transition-colors">
            + Sprint
          </button>
        )}
        
        {access.role !== 'viewer' && (
          <button id="btn-new-issue" class="bg-forge-secondary text-forge-bg font-bold px-3 py-1.5 rounded-md text-sm hover:opacity-90 transition-opacity ml-2">
            + Issue
          </button>
        )}
      </div>
    </header>

    <div class="flex-1 overflow-hidden">
      <!-- Pass sprints to KanbanBoard so IssueDetailsModal can use it -->
      <KanbanBoard workspaceId={workspace.id} issues={issues} sprints={sprints} currentSprintId={activeSprintId} workspaceMembers={workspaceMembers} userRole={access.role} />
    </div>
  </div>

  <!-- New Sprint Modal -->
  <dialog id="new-sprint-modal" class="bg-forge-panel border border-forge-border rounded-lg p-6 w-full max-w-[400px] text-forge-text shadow-xl backdrop:bg-black/50">
    <h2 class="text-xl font-bold mb-4">Create Sprint</h2>
    <div class="mb-4">
      <label class="block text-xs uppercase tracking-wider text-forge-muted mb-1">Name</label>
      <input type="text" id="sprint-name" class="w-full bg-forge-bg border border-forge-border rounded p-2 text-forge-text focus:outline-none focus:border-forge-secondary" placeholder="E.g. Sprint 4">
    </div>
    <div class="flex justify-end gap-3 mt-6">
      <button type="button" class="px-4 py-2 text-forge-muted hover:text-forge-text" onclick="document.getElementById('new-sprint-modal').close()">Cancel</button>
      <button type="button" id="btn-save-sprint" class="bg-forge-primary text-forge-bg px-4 py-2 rounded font-bold hover:bg-opacity-90 transition-colors">Create</button>
    </div>
  </dialog>

  <!-- New Issue Modal -->
  <dialog id="new-issue-modal" class="bg-forge-panel border border-forge-border rounded-lg p-6 w-full max-w-[500px] text-forge-text shadow-xl backdrop:bg-black/50">
    <h2 class="text-xl font-bold mb-4">{t('modal.create_issue')}</h2>
    <div class="space-y-4">
      <div>
        <label class="block text-xs uppercase tracking-wider text-forge-muted mb-1">{t('modal.title')}</label>
        <input type="text" id="new-issue-title" class="w-full bg-forge-bg border border-forge-border rounded p-2 text-forge-text focus:border-forge-secondary outline-none" placeholder={t('modal.title_placeholder') as string}>
      </div>
      <div>
        <label class="block text-xs uppercase tracking-wider text-forge-muted mb-1">{t('modal.type')}</label>
        <select id="new-issue-type" class="w-full bg-forge-bg border border-forge-border rounded p-2 text-forge-text focus:border-forge-secondary outline-none">
          <option value="task">Task</option>
          <option value="bug">Bug</option>
          <option value="story">Story</option>
        </select>
      </div>
      <div>
        <label class="block text-xs uppercase tracking-wider text-forge-muted mb-1">{t('modal.sprint')}</label>
        <select id="new-issue-sprint" class="w-full bg-forge-bg border border-forge-border rounded p-2 text-forge-text focus:border-forge-secondary outline-none">
          <option value="">{t('modal.backlog')}</option>
          {sprints.map(s => (
            <option value={s.id} selected={activeSprintId === s.id}>{s.name}</option>
          ))}
        </select>
      </div>
    </div>
    <div class="flex justify-end gap-3 mt-6">
      <button type="button" class="px-4 py-2 text-forge-muted hover:text-forge-text" onclick="document.getElementById('new-issue-modal').close()">{t('modal.cancel')}</button>
      <button type="button" id="btn-save-issue" class="bg-forge-secondary text-forge-bg px-4 py-2 rounded font-bold hover:opacity-90 transition-opacity">{t('modal.create')}</button>
    </div>
  </dialog>

  <script>
    const workspaceId = document.querySelector('.kanban-container')?.getAttribute('data-workspace') || 'default';

    // PERSIST SPRINT SELECTION
    const urlParams = new URLSearchParams(window.location.search);
    const sprintParam = urlParams.get('sprint');
    
    // If no sprint param is present at all (not even empty), check localStorage
    if (!window.location.search.includes('sprint=')) {
      const savedSprint = localStorage.getItem(`forge_last_sprint_${workspaceId}`);
      if (savedSprint && savedSprint !== 'backlog') {
        const newUrl = new URL(window.location.href);
        newUrl.searchParams.set('sprint', savedSprint);
        window.location.replace(newUrl.toString());
      } else if (!savedSprint) {
        localStorage.setItem(`forge_last_sprint_${workspaceId}`, 'backlog');
      }
    } else {
      // Save current sprint to localStorage
      localStorage.setItem(`forge_last_sprint_${workspaceId}`, sprintParam || 'backlog');
    }

    // SPRINT SELECTOR
    const selector = document.getElementById('sprint-selector') as HTMLSelectElement;
    selector?.addEventListener('change', (e) => {
      const val = (e.target as HTMLSelectElement).value;
      localStorage.setItem(`forge_last_sprint_${workspaceId}`, val);
      const url = new URL(window.location.href);
      if (val === 'backlog') {
        url.searchParams.delete('sprint');
      } else {
        url.searchParams.set('sprint', val);
      }
      window.location.href = url.toString();
    });

    // NEW SPRINT MODAL
    const newSprintBtn = document.getElementById('btn-new-sprint');
    const sprintModal = document.getElementById('new-sprint-modal') as HTMLDialogElement;
    const saveSprintBtn = document.getElementById('btn-save-sprint');

    newSprintBtn?.addEventListener('click', () => sprintModal?.showModal());

    saveSprintBtn?.addEventListener('click', async () => {
      const name = (document.getElementById('sprint-name') as HTMLInputElement).value;
      if (!name) return alert('Name required');
      
      const res = await fetch('/api/sprints', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, workspaceId })
      });
      
      if (res.ok) {
        const data = await res.json();
        const url = new URL(window.location.href);
        url.searchParams.set('sprint', data.id);
        window.location.href = url.toString();
      } else {
        console.error('API Error: ', await res.text());
      }
    });

    // NEW ISSUE MODAL
    const newIssueBtn = document.getElementById('btn-new-issue');
    const issueModal = document.getElementById('new-issue-modal') as HTMLDialogElement;
    const saveIssueBtn = document.getElementById('btn-save-issue');

    newIssueBtn?.addEventListener('click', () => issueModal?.showModal());

    saveIssueBtn?.addEventListener('click', async () => {
      const title = (document.getElementById('new-issue-title') as HTMLInputElement).value;
      const type = (document.getElementById('new-issue-type') as HTMLSelectElement).value;
      const sprintId = (document.getElementById('new-issue-sprint') as HTMLSelectElement).value;

      if (!title) return alert('Title is required');

      const res = await fetch('/api/issues', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ title, type, sprint_id: sprintId || null, workspace_id: workspaceId })
      });

      if (res.ok) {
        window.location.reload();
      } else {
        alert(await res.text());
      }
    });

    // SPRINT TOGGLE (START/COMPLETE/REOPEN)
    const toggleSprintBtn = document.getElementById('btn-toggle-sprint');
    toggleSprintBtn?.addEventListener('click', async (e) => {
      const btn = e.currentTarget as HTMLElement;
      const sprintId = btn.getAttribute('data-sprint-id');
      const currentStatus = btn.getAttribute('data-current-status');
      
      let newStatus = 'active';
      if (currentStatus === 'active') newStatus = 'completed';
      if (currentStatus === 'completed') newStatus = 'active'; // Allow reopening if they are looking at a completed sprint

      let promptText = `Are you sure you want to ${newStatus === 'completed' ? 'complete' : 'start/reopen'} this sprint?`;

      if (newStatus === 'completed') {
        const incompleteCards = document.querySelectorAll('.board-column:not([data-status="done"]) .issue-card').length;
        if (incompleteCards > 0) {
          promptText = `WARNING: There are ${incompleteCards} incomplete task(s). Are you sure you want to complete this sprint anyway?`;
        }
      }
      
      // @ts-ignore
      window.forgeConfirm(promptText, async () => {
        const res = await fetch(`/api/sprints/${sprintId}`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ status: newStatus, workspaceId })
        });

        if (res.ok) {
          window.location.reload();
        } else {
          // @ts-ignore
          window.showToast(await res.text(), true);
        }
      });
    });

    const deactivateSprintBtn = document.getElementById('btn-deactivate-sprint');
    deactivateSprintBtn?.addEventListener('click', async (e) => {
      const btn = e.currentTarget as HTMLElement;
      const sprintId = btn.getAttribute('data-sprint-id');
      
      // @ts-ignore
      window.forgeConfirm(`Deactivate this sprint? It will return to the planning stage.`, async () => {
        const res = await fetch(`/api/sprints/${sprintId}`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ status: 'planned', workspaceId })
        });

        if (res.ok) {
          window.location.reload();
        } else {
          // @ts-ignore
          window.showToast(await res.text(), true);
        }
      });
    });
  </script>
  <script>
    // Update sprint time counter dynamically
    window.addEventListener('worklog-changed', (e: any) => {
      const container = document.getElementById('sprint-time-container');
      const text = document.getElementById('sprint-time-text');
      const bar = document.getElementById('sprint-time-bar');
      if (!container || !text || !bar) return;

      const delta = e.detail.hoursDelta;
      let logged = parseFloat(container.getAttribute('data-logged') || '0');
      const estimated = parseFloat(container.getAttribute('data-estimated') || '0');

      logged = Math.max(0, logged + delta);
      container.setAttribute('data-logged', logged.toString());

      // Format rounding to 1 decimal to avoid floating point weirdness like 3.40000000001
      const displayLogged = Math.round(logged * 10) / 10;
      const displayEst = Math.round(estimated * 10) / 10;

      text.textContent = `${displayLogged}h / ${estimated > 0 ? displayEst + 'h' : '0h'}`;

      if (estimated > 0) {
        const pct = Math.min((logged / estimated) * 100, 100);
        bar.style.width = `${pct}%`;
        if (logged / estimated > 1) {
          bar.className = 'h-full transition-all bg-red-500';
        } else {
          bar.className = 'h-full transition-all bg-forge-secondary';
        }
      }
    });
  </script>
</MainLayout>
