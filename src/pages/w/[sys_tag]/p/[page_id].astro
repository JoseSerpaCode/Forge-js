---
import MainLayout from '../../../../layouts/MainLayout.astro';
import PageTree from '../../../../components/notion/PageTree.astro';
import EditorClient from '../../../../components/notion/EditorClient.astro';
import db from '../../../../lib/db';
import { checkWorkspaceAccess } from '../../../../lib/guard';

const user = Astro.locals.user!;
if (!user) return Astro.redirect('/login');

const { sys_tag, page_id } = Astro.params;
const ws = db.prepare('SELECT id FROM workspaces WHERE sys_tag = ?').get(sys_tag) as any;
if (!ws) return Astro.redirect('/404');

// Guard check for read access
const access = checkWorkspaceAccess(user.id, user.is_sysadmin, ws.id, 'viewer');
if (!access.granted) return new Response(access.error, { status: 403 });

// Determine edit capabilities
const editAccess = checkWorkspaceAccess(user.id, user.is_sysadmin, ws.id, 'editor');
const canEdit = editAccess.granted;

// Fetch page with author info
const page = db.prepare(`
  SELECT p.*, u.username as author_name, u.avatar_url as author_avatar
  FROM pages p
  LEFT JOIN users u ON p.created_by = u.id
  WHERE p.id = ? AND p.workspace_id = ?
`).get(page_id, ws.id) as any;
if (!page) return new Response('Page not found', { status: 404 });

// Fetch parent page title for breadcrumb (optional, just 1 level for now)
let parentTitle = null;
let parentId = null;
if (page.parent_page_id) {
  const parent = db.prepare('SELECT id, title FROM pages WHERE id = ?').get(page.parent_page_id) as any;
  if (parent) {
    parentTitle = parent.title;
    parentId = parent.id;
  }
}
---

<MainLayout hideFooter={true} title={`${page.title} | Knowledge Base`} workspaceId={ws.id}>
  <div class="flex h-full overflow-hidden">
    <PageTree workspaceId={ws.id} sysTag={sys_tag!} currentPageId={page.id} />
    
    <EditorClient 
      pageId={page.id} 
      initialTitle={page.title} 
      initialContent={page.content_json} 
      canEdit={canEdit}
      authorName={page.author_name}
      authorAvatar={page.author_avatar}
      updatedAt={page.updated_at}
      createdAt={page.created_at}
      parentTitle={parentTitle}
      parentId={parentId}
      sysTag={sys_tag!}
    />
  </div>
</MainLayout>
