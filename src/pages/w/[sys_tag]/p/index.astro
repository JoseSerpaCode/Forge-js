---
import MainLayout from '../../../../layouts/MainLayout.astro';
import PageTree from '../../../../components/notion/PageTree.astro';
import db from '../../../../lib/db';
import { checkWorkspaceAccess } from '../../../../lib/guard';
import { useTranslations } from '../../../../i18n/ui';

const lang = Astro.locals.lang || 'en';
const t = useTranslations(lang);

const user = Astro.locals.user!;
if (!user) return Astro.redirect('/login');

const { sys_tag } = Astro.params;
const ws = db.prepare('SELECT id FROM workspaces WHERE sys_tag = ?').get(sys_tag) as any;
if (!ws) return Astro.redirect('/404');

// [M-4 FIX] Verify the user is a member before revealing any page IDs or content
const access = checkWorkspaceAccess(user.id, user.is_sysadmin, ws.id, 'viewer');
if (!access.granted) return Astro.redirect('/404');

let targetPageId = null;

// Intentar usar la última página visitada por el usuario
if (user.last_page_id) {
  const lastPage = db.prepare('SELECT id FROM pages WHERE id = ? AND workspace_id = ?').get(user.last_page_id, ws.id) as any;
  if (lastPage) targetPageId = lastPage.id;
}

// Fallback a la primera página si no hay historial
if (!targetPageId) {
  const firstPage = db.prepare('SELECT id FROM pages WHERE workspace_id = ? ORDER BY created_at ASC LIMIT 1').get(ws.id) as any;
  if (firstPage) targetPageId = firstPage.id;
}

if (targetPageId) {
  return Astro.redirect(`/w/${sys_tag}/p/${targetPageId}`);
}
---

<MainLayout hideFooter={true} title="Knowledge Base | Forge JS">
  <div class="flex h-full overflow-hidden">
    <PageTree workspaceId={ws.id} sysTag={sys_tag!} />
    
    <div class="flex-1 flex flex-col items-center justify-center text-forge-muted">
      <div class="w-16 h-16 border border-dashed border-forge-border rounded-lg flex items-center justify-center mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/></svg>
      </div>
      <div class="text-forge-text font-bold text-lg mb-2">{t('kb.empty_desc')}</div>
      <div class="text-forge-muted text-sm">{t('kb.empty_cta')}</div>
    </div>
  </div>
</MainLayout>
