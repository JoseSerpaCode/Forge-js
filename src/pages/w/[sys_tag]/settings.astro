---
import MainLayout from '../../../layouts/MainLayout.astro';
import db from '../../../lib/db';
import { checkWorkspaceAccess } from '../../../lib/guard';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/login');

const { sys_tag } = Astro.params;

const ws = db.prepare('SELECT * FROM workspaces WHERE sys_tag = ?').get(sys_tag) as any;
if (!ws) return Astro.redirect('/404');

const access = checkWorkspaceAccess(user.id, user.is_sysadmin, ws.id, 'owner');
if (!access.granted) return Astro.redirect(`/w/${sys_tag}`); // Only owners can access settings

const members = db.prepare(`
  SELECT u.id, u.username, u.avatar_url, wm.ws_role, wm.joined_at
  FROM workspace_members wm
  JOIN users u ON wm.user_id = u.id
  WHERE wm.workspace_id = ?
  ORDER BY wm.joined_at ASC
`).all(ws.id) as any[];

const auditLogs = db.prepare(`
  SELECT a.id, a.action, a.entity_type, a.entity_id, a.details_json, a.timestamp, u.username, u.avatar_url
  FROM audit_logs a
  LEFT JOIN users u ON a.user_id = u.id
  WHERE a.workspace_id = ?
  ORDER BY a.timestamp DESC
  LIMIT 50
`).all(ws.id) as any[];

const automations = db.prepare(`
  SELECT id, name, trigger_type, trigger_condition, action_type, action_payload, is_active
  FROM automations
  WHERE workspace_id = ?
`).all(ws.id) as any[];
---

<MainLayout title={`Settings - ${ws.name}`} workspaceId={ws.id}>
  <div class="max-w-4xl mx-auto mt-4 sm:mt-10 p-0 sm:p-6 space-y-6 sm:space-y-8 relative">
    <div class="flex items-center justify-between">
      <h1 class="text-3xl font-bold text-forge-text">{t('ws.settings.title')}</h1>
      <a href={`/w/${sys_tag}`} class="text-forge-muted hover:text-forge-text text-sm hover:underline">{t('ws.settings.back')}</a>
    </div>

    <!-- General Settings -->
    <div class="bg-forge-panel border border-forge-border rounded-lg shadow-lg p-6">
      <h2 class="text-xl font-bold text-forge-text mb-6 border-b border-forge-border pb-2">{t('ws.settings.general')}</h2>
      <div class="flex flex-col md:flex-row items-start gap-6">
        <div class="relative w-32 h-32 rounded-xl border-2 border-dashed border-forge-border hover:border-forge-secondary flex items-center justify-center bg-forge-bg overflow-hidden group cursor-pointer shrink-0" id="ws-icon-preview-container">
          {ws.icon && ws.icon.startsWith('data:image') ? (
            <img src={ws.icon} class="w-full h-full object-cover" id="ws-icon-preview-img" alt="Workspace Icon" loading="lazy" />
          ) : (
            <div class="text-4xl font-black text-forge-secondary" id="ws-icon-preview-text">
              {ws.icon || ws.name.charAt(0).toUpperCase()}
            </div>
          )}
          <div class="absolute inset-0 bg-black/60 hidden group-hover:flex items-center justify-center transition-all z-10 flex-col">
            <span class="text-[10px] font-bold text-white uppercase tracking-widest text-center px-2">{t('ws.settings.upload')}</span>
          </div>
          <input type="file" id="ws-icon-file-input" accept="image/*" class="absolute inset-0 opacity-0 cursor-pointer z-20" title="Upload image icon" />
        </div>
        
        <div class="flex-1 space-y-4">
          <div>
            <label class="block text-sm font-bold text-forge-muted uppercase mb-1">{t('ws.settings.name')}</label>
            <input type="text" id="ws-name-input" value={ws.name} class="w-full bg-forge-bg border border-forge-border rounded p-2 text-forge-text focus:outline-none focus:border-forge-secondary" />
          </div>
          <div>
            <label class="block text-sm font-bold text-forge-muted uppercase mb-1">{t('ws.settings.tag')}</label>
            <input type="text" id="ws-tag-input" value={ws.sys_tag} class="w-full bg-forge-bg border border-forge-border rounded p-2 text-forge-text focus:outline-none focus:border-forge-secondary" />
          </div>
          <button id="btn-save-general" class="bg-forge-primary text-forge-bg font-bold py-2 px-6 rounded hover:bg-forge-primary/90 transition-colors mt-2" data-ws-id={ws.id}>
            {t('ws.settings.save')}
          </button>
        </div>
      </div>
    </div>

    <!-- Members -->
    <div class="bg-forge-panel border border-forge-border rounded-lg shadow-lg p-6">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-bold text-forge-text">{t('ws.settings.members')}</h2>
        <button id="btn-add-member" class="bg-forge-bg border border-forge-border text-forge-text px-3 py-1.5 text-sm rounded hover:border-forge-secondary transition-colors">
          {t('ws.settings.invite')}
        </button>
      </div>

      <div class="space-y-3">
        {members.map((m) => (
          <div class="flex items-center justify-between bg-forge-bg border border-forge-border p-3 rounded">
            <div class="flex items-center gap-3">
              {m.avatar_url ? (
                <img src={m.avatar_url} class="w-8 h-8 rounded-full border border-forge-border object-cover" alt={`${m.username} avatar`} loading="lazy" />
              ) : (
                <div class="w-8 h-8 rounded-full border border-forge-border flex items-center justify-center text-forge-secondary shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                </div>
              )}
              <span class="font-bold text-forge-text">{m.username}</span>
            </div>
            
            <div class="flex items-center gap-3">
              <select class="role-select bg-forge-panel border border-forge-border text-forge-muted text-sm rounded p-1 focus:outline-none focus:border-forge-secondary" data-user-id={m.id} data-ws-id={ws.id}>
                <option value="owner" selected={m.ws_role === 'owner'}>{t('ws.settings.role_owner')}</option>
                <option value="editor" selected={m.ws_role === 'editor'}>{t('ws.settings.role_editor')}</option>
                <option value="commenter" selected={m.ws_role === 'commenter'}>{t('ws.settings.role_commenter') || 'Commenter'}</option>
                <option value="viewer" selected={m.ws_role === 'viewer'}>{t('ws.settings.role_viewer')}</option>
              </select>
              
              <button class="btn-remove-member text-forge-muted hover:text-red-400 p-1 rounded hover:bg-red-500/10 transition-colors" data-user-id={m.id} data-ws-id={ws.id} title="Remove User">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
              </button>
            </div>
          </div>
        ))}
      </div>
    </div>
    
    <!-- Automations Engine -->
    <div class="bg-forge-panel border border-forge-border rounded-lg shadow-lg p-6">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-bold text-forge-text flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-forge-secondary"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg>
          {t('ws.settings.automations')}
        </h2>
        <button id="btn-add-automation" class="bg-forge-secondary text-forge-bg font-bold px-3 py-1.5 text-sm rounded hover:opacity-90 transition-opacity">
          {t('ws.settings.new_rule')}
        </button>
      </div>

      <div class="space-y-4">
        {automations.map((auto: any) => (
          <div class="flex items-center justify-between bg-forge-bg/50 border border-forge-border p-4 rounded-lg">
            <div class="flex flex-col">
              <span class="font-bold text-forge-text text-sm">{auto.name}</span>
              <span class="text-[10px] font-mono text-forge-muted mt-1 uppercase">IF {auto.trigger_type} THEN {auto.action_type}</span>
            </div>
            <div class="flex items-center gap-4">
              <label class="flex items-center cursor-pointer">
                <div class="relative">
                  <input type="checkbox" class="sr-only toggle-automation-active" data-id={auto.id} checked={auto.is_active === 1}>
                  <div class="block bg-forge-panel border border-forge-border w-8 h-5 rounded-full transition-colors"></div>
                  <div class="dot absolute left-1 top-1 bg-forge-muted w-3 h-3 rounded-full transition-transform"></div>
                </div>
              </label>
              <button class="btn-delete-automation text-forge-muted hover:text-red-400 p-1 rounded hover:bg-red-500/10 transition-colors" data-id={auto.id} title="Delete Rule">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
              </button>
            </div>
          </div>
        ))}
        {automations.length === 0 && (
          <div class="py-6 text-center text-forge-muted text-sm border border-dashed border-forge-border rounded-lg bg-forge-bg/30">
            {t('ws.settings.no_rules')}
          </div>
        )}
      </div>
    </div>
    
    <!-- Audit Logs -->
    <div class="bg-forge-panel border border-forge-border rounded-lg shadow-lg p-6 overflow-hidden flex flex-col max-h-[600px]">
      <div class="flex items-center justify-between mb-6 shrink-0">
        <h2 class="text-xl font-bold text-forge-text flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-forge-secondary"><path d="M12 20h9"></path><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"></path></svg>
          {t('ws.settings.audit')}
        </h2>
        <span class="text-xs text-forge-muted font-mono bg-forge-bg px-2 py-1 rounded">{t('ws.settings.last_events')}</span>
      </div>
      
      <div class="overflow-y-auto pr-2 -mr-2 space-y-2 flex-1">
        {auditLogs.map((log: any) => {
          const date = new Date(log.timestamp.replace(' ', 'T') + 'Z').toLocaleString();
          let detailsText = '';
          try {
            const details = JSON.parse(log.details_json);
            if (details) {
              detailsText = Object.entries(details).map(([k, v]) => `${k}: ${v}`).join(', ');
            }
          } catch (e) {}
          
          return (
            <div class="flex flex-col p-3 rounded-lg bg-forge-bg/50 border border-forge-border/40 hover:border-forge-secondary/30 transition-colors">
              <div class="flex justify-between items-start mb-2">
                <div class="flex items-center gap-2">
                  <div class="w-6 h-6 rounded-full overflow-hidden bg-forge-panel shrink-0 border border-forge-border">
                    <img src={log.avatar_url || '/default-avatar.svg'} alt={log.username} class="w-full h-full object-cover" />
                  </div>
                  <span class="text-sm font-bold text-forge-text">{log.username || 'System'}</span>
                  <span class="text-xs text-forge-muted uppercase tracking-wider bg-forge-panel px-1.5 py-0.5 rounded border border-forge-border/50">{log.action}</span>
                </div>
                <span class="text-[10px] text-forge-muted font-mono">{date}</span>
              </div>
              <div class="text-xs text-forge-text/80 pl-8">
                <span class="font-bold text-forge-secondary">{log.entity_type}</span>: <span class="font-mono text-forge-muted">{log.entity_id.substring(0,8)}</span>
                {detailsText && <p class="mt-1 font-mono text-[10px] text-forge-muted/70 truncate" title={detailsText}>{detailsText}</p>}
              </div>
            </div>
          );
        })}
        {auditLogs.length === 0 && (
          <div class="py-8 text-center text-forge-muted text-sm font-mono">
            No audit logs recorded yet.
          </div>
        )}
      </div>
    </div>
    
    <!-- Danger Zone -->
    <div class="bg-red-500/5 border border-red-500/20 rounded-lg shadow-lg p-6">
      <h2 class="text-xl font-bold text-red-500 mb-2">{t('ws.settings.danger')}</h2>
      <p class="text-forge-muted text-sm mb-4">{t('ws.settings.danger_desc')}</p>
      <button id="btn-delete-workspace" class="bg-red-500/10 text-red-500 border border-red-500/30 px-4 py-2 rounded font-bold hover:bg-red-500 hover:text-white transition-colors" data-ws-id={ws.id}>
        {t('ws.settings.delete')}
      </button>
    </div>

  </div>

  <dialog id="add-member-modal" class="bg-forge-panel border border-forge-border rounded-lg p-6 w-full max-w-[400px] text-forge-text shadow-xl backdrop:bg-black/50">
    <h2 class="text-xl font-bold mb-4">{t('ws.settings.modal_add_member')}</h2>
    <div class="mb-4">
      <label class="block text-xs uppercase tracking-wider text-forge-muted mb-1">{t('ws.settings.modal_username')}</label>
      <input type="text" id="add-member-username" class="w-full bg-forge-bg border border-forge-border rounded p-2 text-forge-text focus:border-forge-secondary focus:outline-none" placeholder={t('ws.settings.modal_username_ph')}>
    </div>
    <div class="mb-4">
      <label class="block text-xs uppercase tracking-wider text-forge-muted mb-1">{t('ws.settings.modal_role')}</label>
      <select id="add-member-role" class="w-full bg-forge-bg border border-forge-border rounded p-2 text-forge-text focus:border-forge-secondary focus:outline-none">
        <option value="viewer">{t('ws.settings.role_viewer')}</option>
        <option value="commenter">{t('ws.settings.role_commenter') || 'Commenter'}</option>
        <option value="editor">{t('ws.settings.role_editor')}</option>
        <option value="owner">{t('ws.settings.role_owner')}</option>
      </select>
    </div>
    <div class="flex justify-end gap-3 mt-6">
      <button type="button" class="px-4 py-2 text-forge-muted hover:text-forge-text" onclick="document.getElementById('add-member-modal').close()">{t('ws.settings.modal_cancel')}</button>
      <button type="button" id="btn-confirm-add" class="bg-forge-secondary text-forge-bg px-4 py-2 rounded font-bold hover:opacity-90 transition-opacity" data-ws-id={ws.id}>{t('ws.settings.modal_send_invite')}</button>
    </div>
  </dialog>

  <!-- Add Automation Modal -->
  <dialog id="add-automation-modal" class="bg-forge-panel border border-forge-border rounded-lg p-6 w-full max-w-[500px] text-forge-text shadow-xl backdrop:bg-black/50">
    <h2 class="text-xl font-bold mb-4 flex items-center gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-forge-secondary"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg>
      {t('ws.settings.modal_create_rule')}
    </h2>
    <div class="space-y-4">
      <div>
        <label class="block text-xs uppercase tracking-wider text-forge-muted mb-1">{t('ws.settings.name')}</label>
        <input type="text" id="auto-name" class="w-full bg-forge-bg border border-forge-border rounded p-2 text-forge-text focus:border-forge-secondary focus:outline-none" placeholder="E.g., Auto-assign to QA">
      </div>
      
      <div class="p-4 rounded border border-forge-border bg-forge-bg/30">
        <label class="block text-sm font-bold text-forge-secondary mb-2 uppercase tracking-wider">{t('ws.settings.modal_trigger')}</label>
        <select id="auto-trigger" class="w-full bg-forge-bg border border-forge-border rounded p-2 text-forge-text focus:border-forge-secondary focus:outline-none">
          <option value="issue.created">Issue Created</option>
          <option value="issue.moved">Issue Moved to Status</option>
          <option value="sprint.started">Sprint Started</option>
          <option value="sprint.completed">Sprint Completed</option>
        </select>
        
        <div id="trigger-condition-container" class="mt-3 hidden">
          <label class="block text-xs uppercase tracking-wider text-forge-muted mb-1">Target Status</label>
          <input type="text" id="auto-trigger-cond" class="w-full bg-forge-bg border border-forge-border rounded p-2 text-forge-text focus:border-forge-secondary focus:outline-none" placeholder="e.g. In Progress">
        </div>
      </div>
      
      <div class="p-4 rounded border border-forge-border bg-forge-bg/30">
        <label class="block text-sm font-bold text-forge-secondary mb-2 uppercase tracking-wider">{t('ws.settings.modal_action')}</label>
        <select id="auto-action" class="w-full bg-forge-bg border border-forge-border rounded p-2 text-forge-text focus:border-forge-secondary focus:outline-none">
          <option value="assign.user">Assign to User</option>
          <option value="add.label">Add Label</option>
          <option value="webhook">Send Webhook (POST)</option>
        </select>
        
        <div class="mt-3">
          <label class="block text-xs uppercase tracking-wider text-forge-muted mb-1">Action Payload</label>
          <input type="text" id="auto-action-payload" class="w-full bg-forge-bg border border-forge-border rounded p-2 text-forge-text focus:border-forge-secondary focus:outline-none" placeholder="e.g. username, or https://...">
        </div>
      </div>
    </div>
    
    <div class="flex justify-end gap-3 mt-6">
      <button type="button" class="px-4 py-2 text-forge-muted hover:text-forge-text" onclick="document.getElementById('add-automation-modal').close()">{t('ws.settings.modal_cancel')}</button>
      <button type="button" id="btn-save-automation" class="bg-forge-secondary text-forge-bg px-4 py-2 rounded font-bold hover:opacity-90 transition-opacity" data-ws-id={ws.id}>{t('ws.settings.modal_save_rule')}</button>
    </div>
  </dialog>

</MainLayout>
<style>
  input:checked + div { background-color: var(--forge-secondary); border-color: var(--forge-secondary); }
  input:checked + div + .dot { transform: translateX(12px); background-color: var(--forge-bg); }
</style>

<script is:inline>
  const wsId = document.getElementById('btn-save-general')?.getAttribute('data-ws-id');
  let newIconUrl = null;
  const iconInput = document.getElementById('ws-icon-file-input');
  
  iconInput?.addEventListener('change', (e) => {
    const file = e.target.files?.[0];
    if (file) {
      if (file.size > 10 * 1024 * 1024) {
        return window.showToast('Image is too massive, keep it under 10MB', true);
      }
      
      const reader = new FileReader();
      reader.onload = (ev) => {
        const img = new Image();
        img.onload = () => {
          const canvas = document.createElement('canvas');
          const MAX_SIZE = 512;
          let width = img.width;
          let height = img.height;

          if (width > height && width > MAX_SIZE) {
            height *= MAX_SIZE / width;
            width = MAX_SIZE;
          } else if (height > MAX_SIZE) {
            width *= MAX_SIZE / height;
            height = MAX_SIZE;
          }

          canvas.width = width;
          canvas.height = height;
          const ctx = canvas.getContext('2d');
          if (ctx) ctx.drawImage(img, 0, 0, width, height);

          canvas.toBlob(async (blob) => {
            if (blob) {
              const formData = new FormData();
              formData.append('entity_type', 'workspace');
              formData.append('entity_id', wsId);
              formData.append('file', blob, 'icon.webp');

              if (window.showToast) window.showToast('Uploading icon...');

              try {
                const res = await fetch('/api/upload', { method: 'POST', body: formData });
                if (res.ok) {
                  const data = await res.json();
                  newIconUrl = data.url;
                  
                  let iconPreview = document.getElementById('ws-icon-preview-img');
                  if (iconPreview) {
                    iconPreview.src = newIconUrl;
                  } else {
                    const container = document.getElementById('ws-icon-preview-container');
                    const defaultText = document.getElementById('ws-icon-preview-text');
                    if (defaultText) defaultText.style.display = 'none';
                    
                    const newImg = document.createElement('img');
                    newImg.src = newIconUrl;
                    newImg.id = 'ws-icon-preview-img';
                    newImg.className = 'w-full h-full object-cover z-0';
                    container?.insertBefore(newImg, container.firstChild);
                  }
                  if (window.showToast) window.showToast('Icon uploaded!');
                } else {
                  if (window.showToast) window.showToast('Failed to upload icon', true);
                }
              } catch (err) {
                console.error(err);
              }
            }
          }, 'image/webp', 0.8);
        };
        img.src = ev.target.result;
      };
      reader.readAsDataURL(file);
    }
  });

  document.getElementById('btn-save-general')?.addEventListener('click', async (e) => {
    const wsIdAttr = e.currentTarget.getAttribute('data-ws-id');
    const name = document.getElementById('ws-name-input').value;
    const description = ""; // Description field removed from UI
    
    let finalIcon = newIconUrl;
    if (!finalIcon) {
       const existingImg = document.getElementById('ws-icon-preview-img');
       if (existingImg) finalIcon = existingImg.src;
       else {
         const existingText = document.getElementById('ws-icon-preview-text');
         if (existingText && existingText.textContent && existingText.textContent.trim().length <= 2) {
            finalIcon = existingText.textContent.trim();
         }
       }
    }

    const res = await fetch(`/api/workspaces/${wsId}`, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name, description, icon: finalIcon })
    });
    
    if (res.ok) {
      window.showToast('Workspace updated!');
    } else {
      window.showToast(await res.text(), true);
    }
  });

  // Members
  document.querySelectorAll('.role-select').forEach(select => {
    select.addEventListener('change', async (e) => {
      const el = e.currentTarget;
      const userId = el.getAttribute('data-user-id');
      const wsId = el.getAttribute('data-ws-id');
      const role = el.value;

      const res = await fetch(`/api/workspaces/${wsId}/members`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ userId, role })
      });
      if (res.ok) {
        window.showToast('Role updated');
      } else {
        window.showToast(await res.text(), true);
        window.location.reload(); // reset select
      }
    });
  });

  document.querySelectorAll('.btn-remove-member').forEach(btn => {
    btn.addEventListener('click', async (e) => {
      const el = e.currentTarget;
      const userId = el.getAttribute('data-user-id');
      const wsId = el.getAttribute('data-ws-id');
      
      window.forgeConfirm('Remove this user from the workspace?', async () => {
        const res = await fetch(`/api/workspaces/${wsId}/members`, {
          method: 'DELETE',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ userId })
        });
        if (res.ok) {
          el.closest('div')?.parentElement?.remove();
          window.showToast('User removed');
        } else {
          window.showToast(await res.text(), true);
        }
      });
    });
  });

  document.getElementById('btn-add-member')?.addEventListener('click', () => {
    document.getElementById('add-member-modal').showModal();
  });

  document.getElementById('btn-confirm-add')?.addEventListener('click', async (e) => {
    const wsId = e.currentTarget.getAttribute('data-ws-id');
    const username = document.getElementById('add-member-username').value;
    const role = document.getElementById('add-member-role').value;
    
    const res = await fetch(`/api/workspaces/${wsId}/members`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ username, role })
    });
    if (res.ok) {
      window.showToast(`Invitation sent to ${username}!`);
      document.getElementById('add-member-username').value = '';
      document.getElementById('add-member-modal').close();
    } else {
      window.showToast(await res.text(), true);
    }
  });

  // Danger
  document.getElementById('btn-delete-workspace')?.addEventListener('click', async (e) => {
    const wsId = e.currentTarget.getAttribute('data-ws-id');
    window.forgeConfirm('DANGER: Delete this workspace entirely?', async () => {
      const res = await fetch(`/api/workspaces/${wsId}`, { method: 'DELETE' });
      if (res.ok) {
        window.location.href = '/';
      } else {
        window.showToast(await res.text(), true);
      }
    });
  });
    // Automations
  document.getElementById('btn-add-automation')?.addEventListener('click', () => {
    document.getElementById('add-automation-modal').showModal();
  });

  document.getElementById('btn-save-automation')?.addEventListener('click', async (e) => {
    const wsId = e.currentTarget.getAttribute('data-ws-id');
    const name = document.getElementById('auto-name').value;
    const trigger_type = document.getElementById('auto-trigger-type').value;
    const trigger_condition = document.getElementById('auto-trigger-cond').value;
    const action_type = document.getElementById('auto-action-type').value;
    const action_payload = document.getElementById('auto-action-payload').value;

    try {
      // validate JSON
      JSON.parse(trigger_condition);
      JSON.parse(action_payload);
    } catch (e) {
      return window.showToast('Invalid JSON in Condition or Payload', true);
    }

    const res = await fetch(`/api/automations`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ workspaceId: wsId, name, trigger_type, trigger_condition, action_type, action_payload })
    });

    if (res.ok) {
      window.location.reload();
    } else {
      window.showToast(await res.text(), true);
    }
  });

  document.querySelectorAll('.btn-delete-automation').forEach(btn => {
    btn.addEventListener('click', async (e) => {
      const id = e.currentTarget.getAttribute('data-id');
      window.forgeConfirm('Delete this automation rule?', async () => {
        const res = await fetch(`/api/automations/${id}`, { method: 'DELETE' });
        if (res.ok) window.location.reload();
      });
    });
  });

  document.querySelectorAll('.toggle-automation-active').forEach(checkbox => {
    checkbox.addEventListener('change', async (e) => {
      const target = e.currentTarget;
      const id = target.getAttribute('data-id');
      const is_active = target.checked ? 1 : 0;
      await fetch(`/api/automations/${id}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ is_active })
      });
    });
  });

</script>
