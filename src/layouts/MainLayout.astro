---
import '../styles/themes.css';
import TopBar from '../components/layout/TopBar.astro';
import Sidebar from '../components/layout/Sidebar.astro';

interface Props {
  title: string;
  workspaceId?: string;
}

const { title, workspaceId } = Astro.props;
const user = Astro.locals.user;
---

<html lang="en" data-theme={user?.theme_preference || 'orion_neon'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | Forge OS</title>
  </head>
  <body class="bg-forge-bg text-forge-text flex h-screen overflow-hidden" data-user-role={user?.role} data-is-sysadmin={user?.is_sysadmin}>
    <Sidebar workspaceId={workspaceId} />
    <div class="flex-1 flex flex-col min-w-0">
      <TopBar />
      <main class="flex-1 overflow-auto p-6">
        <slot />
      </main>
    </div>
  </body>
</html>
