---
import '../styles/themes.css';
import TopBar from '../components/layout/TopBar.astro';
import Sidebar from '../components/layout/Sidebar.astro';
import Footer from '../components/layout/Footer.astro';

interface Props {
  title: string;
  workspaceId?: string;
  description?: string;
  ogImage?: string;
  hideFooter?: boolean;
}

const { title, workspaceId, description, ogImage, hideFooter = false } = Astro.props;
const user = Astro.locals.user!;

import db from '../lib/db';
let workspaceName = '';
if (workspaceId) {
  const ws = db.prepare('SELECT name FROM workspaces WHERE id = ?').get(workspaceId) as any;
  if (ws) workspaceName = ws.name;
}

const metaDesc = description || "Forge OS - Advanced workspace management and task tracking application for professional teams.";
const metaImg = ogImage || "/forge-icon.svg";

// Prevent BFCache and caching to ensure data is always fresh and 404s trigger correctly
Astro.response.headers.set('Cache-Control', 'no-store, no-cache, must-revalidate, max-age=0');
Astro.response.headers.set('Pragma', 'no-cache');
---

<html lang={Astro.locals.lang || 'es'} data-theme={user?.theme_preference || 'dark'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=5" />
    <meta name="description" content={metaDesc} />
    <meta name="keywords" content="workspace, kanban, knowledge base, forge os, team collaboration, productivity" />
    <meta name="author" content="Forge OS" />
    <meta name="theme-color" content="#FF5D00" />
    
    <!-- Open Graph / Social -->
    <meta property="og:title" content={`${title} | Forge OS`} />
    <meta property="og:description" content={metaDesc} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    {ogImage && <meta property="og:image" content={metaImg} />}
    
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | Forge OS`} />
    <meta name="twitter:description" content={metaDesc} />
    {ogImage && <meta name="twitter:image" content={metaImg} />}
    
    <link rel="canonical" href={Astro.url.href} />
    
    <!-- Preconnect & Preload for Performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
    
    <link rel="icon" type="image/svg+xml" href="/forge-icon.svg" />
    
    <title>{title} | Forge OS</title>
    <script is:inline>
      const savedTheme = localStorage.getItem('forge_theme');
      if (savedTheme) {
        document.documentElement.setAttribute('data-theme', savedTheme);
      }
    </script>
    <script src="/socket.io/socket.io.js" is:inline></script>
    <script is:inline>
      window.socket = io();
      window.socket.on('user_notification', (data) => {
        if (window.showToast) {
          window.showToast(data.title + ': ' + data.message);
        }
        // Emit custom event so TopBar can catch it
        window.dispatchEvent(new CustomEvent('forge_new_notif', { detail: data }));
      });
    </script>
  </head>
  <body class="bg-forge-bg text-forge-text flex h-screen overflow-hidden selection:bg-forge-primary selection:text-white" data-user-role={user?.role} data-is-sysadmin={user?.is_sysadmin}>
    <Sidebar workspaceId={workspaceId} workspaceName={workspaceName} />
    <div id="sidebar-backdrop" class="fixed inset-0 bg-black/60 z-40 hidden md:hidden transition-opacity opacity-0 backdrop-blur-sm cursor-pointer"></div>
    <div class="flex-1 flex flex-col min-w-0">
      <TopBar title={title} workspaceName={workspaceName} />
      <main class="flex-1 overflow-auto flex flex-col relative min-h-0">
        <div class="max-w-[1440px] w-full mx-auto px-6 py-6 flex-1 shrink-0">
          <slot />
        </div>
        {!hideFooter && <Footer />}
      </main>
    </div>
    
    <!-- Global UI Components -->
    <div id="forge-toast" class="fixed bottom-6 right-6 bg-forge-panel/95 backdrop-blur-md border border-forge-border/50 text-forge-text px-6 py-4 rounded-xl shadow-[0_10px_40px_rgba(0,0,0,0.3)] transform translate-y-20 opacity-0 transition-all duration-400 ease-out z-[100] flex items-center gap-4">
      <span id="forge-toast-icon" class="text-forge-secondary flex-shrink-0 bg-forge-secondary/10 p-1.5 rounded-full">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="M12 8v4"></path><path d="M12 16h.01"></path></svg>
      </span>
      <span id="forge-toast-msg" class="text-sm font-semibold tracking-wide"></span>
    </div>

    <dialog id="forge-confirm-modal" class="bg-forge-panel/95 backdrop-blur-xl border border-forge-border/50 rounded-2xl p-8 w-[420px] text-forge-text shadow-[0_20px_60px_rgba(0,0,0,0.5)] backdrop:bg-black/50 backdrop:backdrop-blur-sm z-[100] open:animate-in open:fade-in open:zoom-in-95 transition-all">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-10 h-10 rounded-full bg-forge-secondary/20 text-forge-secondary flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        </div>
        <h2 class="text-xl font-bold text-forge-text" id="forge-confirm-title">Confirm</h2>
      </div>
      <p class="text-sm text-forge-muted mb-8 leading-relaxed" id="forge-confirm-msg">Are you sure you want to proceed?</p>
      <div class="flex justify-end gap-3">
        <button id="btn-forge-confirm-cancel" class="px-5 py-2.5 text-sm font-semibold text-forge-muted hover:text-forge-text hover:bg-forge-text/5 rounded-lg transition-all cursor-pointer">Cancel</button>
        <button id="btn-forge-confirm-ok" class="bg-forge-primary text-forge-bg px-5 py-2.5 rounded-lg text-sm font-bold shadow-lg shadow-forge-primary/25 hover:shadow-forge-primary/40 hover:-translate-y-0.5 transition-all cursor-pointer">Confirm</button>
      </div>
    </dialog>

    <!-- Command Palette (Cmd+K) -->
    <dialog id="cmd-k-palette" class="bg-forge-panel/95 backdrop-blur-md border border-forge-border rounded-xl p-0 w-full max-w-[550px] text-forge-text shadow-[0_20px_50px_rgba(0,0,0,0.5)] z-[200] overflow-hidden m-auto mb-auto mt-[15vh] transition-all open:animate-in open:fade-in open:zoom-in-95 backdrop:bg-black/40 backdrop:backdrop-blur-sm">
      <div class="flex items-center px-4 py-4 border-b border-forge-border/50 bg-forge-bg/30">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-forge-secondary mr-3"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        <input type="text" id="cmd-k-input" class="w-full bg-transparent border-none text-forge-text text-lg focus:outline-none placeholder-forge-muted/70 font-medium" placeholder="Search commands, workspaces, jump to..." autocomplete="off">
        <span class="text-[10px] font-mono text-forge-muted bg-forge-bg px-2 py-1 rounded border border-forge-border ml-2 font-bold tracking-widest shadow-sm">ESC</span>
      </div>
      <div class="max-h-[350px] overflow-y-auto p-2" id="cmd-k-results">
        <div class="px-3 py-2 text-[10px] font-bold text-forge-muted uppercase tracking-widest mt-1">Quick Actions</div>
        <a href="/" class="flex items-center gap-3 px-3 py-3 rounded-lg hover:bg-forge-secondary/15 hover:text-forge-secondary transition-all cursor-pointer text-sm font-medium group">
          <div class="w-8 h-8 rounded bg-forge-bg border border-forge-border flex items-center justify-center group-hover:border-forge-secondary/50 group-hover:text-forge-secondary text-forge-muted transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          </div>
          Go to Dashboard
        </a>
        <a href="/settings" class="flex items-center gap-3 px-3 py-3 rounded-lg hover:bg-forge-secondary/15 hover:text-forge-secondary transition-all cursor-pointer text-sm font-medium group mt-1">
          <div class="w-8 h-8 rounded bg-forge-bg border border-forge-border flex items-center justify-center group-hover:border-forge-secondary/50 group-hover:text-forge-secondary text-forge-muted transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></svg>
          </div>
          Account Settings
        </a>
      </div>
    </dialog>

    <script is:inline>
      window.showToast = function(msg, type = false) {
        const toast = document.getElementById('forge-toast');
        const text = document.getElementById('forge-toast-msg');
        if (toast && text) {
          text.textContent = msg;
          const isError = type === true || type === 'error';
          if (isError) {
             toast.classList.replace('border-forge-secondary', 'border-red-500');
          } else {
             toast.classList.replace('border-red-500', 'border-forge-secondary');
          }
          toast.classList.remove('translate-y-20', 'opacity-0');
          setTimeout(() => {
            toast.classList.add('translate-y-20', 'opacity-0');
          }, 4000);
        }
      };

      // Generic intercept for guest-restricted actions globally
      document.addEventListener('click', (e) => {
        const restrictedEl = e.target.closest('.guest-restricted-action');
        if (restrictedEl && restrictedEl.getAttribute('data-guest') === 'true') {
          e.preventDefault();
          e.stopPropagation();
          const msg = restrictedEl.getAttribute('data-guest-msg') || 'Please create an account to access this feature.';
          if (window.showToast) window.showToast(msg, true);
          setTimeout(() => window.location.href = '/register', 1500);
        }
      }, true); // Use capture phase to ensure we intercept before other listeners

      window.forgeConfirm = function(msg, callback, title = "Confirm") {
        const modal = document.getElementById('forge-confirm-modal');
        const titleEl = document.getElementById('forge-confirm-title');
        const msgEl = document.getElementById('forge-confirm-msg');
        const btnCancel = document.getElementById('btn-forge-confirm-cancel');
        const btnOk = document.getElementById('btn-forge-confirm-ok');
        
        if (modal && titleEl && msgEl && btnCancel && btnOk) {
          titleEl.textContent = title;
          msgEl.textContent = msg;
          
          const handleCancel = () => {
             modal.close();
             cleanup();
          };
          const handleOk = () => {
             modal.close();
             cleanup();
             callback();
          };
          
          btnCancel.addEventListener('click', handleCancel);
          btnOk.addEventListener('click', handleOk);
          
          const cleanup = () => {
             btnCancel.removeEventListener('click', handleCancel);
             btnOk.removeEventListener('click', handleOk);
          };
          
          modal.showModal();
        } else {
          if (confirm(msg)) callback();
        }
      };

      // Global Keyboard Shortcuts
      document.addEventListener('keydown', (e) => {
        // Prevent shortcuts if typing in input, textarea, or contenteditable
        const tag = e.target.tagName;
        if (['INPUT', 'TEXTAREA', 'SELECT'].includes(tag) || e.target.isContentEditable) return;

        // Cmd+K or Ctrl+K for Palette
        if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
          e.preventDefault();
          const palette = document.getElementById('cmd-k-palette');
          if (palette) {
            if (palette.hasAttribute('open')) {
              palette.close();
            } else {
              palette.showModal();
              document.getElementById('cmd-k-input').focus();
            }
          }
        }


        // 'c' to quickly create issue if button exists
        if (e.key === 'c' || e.key === 'C') {
          const newIssueBtn = document.getElementById('btn-new-issue');
          if (newIssueBtn) {
            e.preventDefault();
            newIssueBtn.click();
          }
        }
        
        // 'b' to toggle sidebar if button exists
        if (e.key === 'b' || e.key === 'B') {
          if (e.metaKey || e.ctrlKey) {
             const toggleBtn = document.getElementById('sidebar-toggle');
             if (toggleBtn) {
               e.preventDefault();
               toggleBtn.click();
             }
          }
        }
      });
      
      // Close on clicking backdrop
      document.getElementById('cmd-k-palette')?.addEventListener('click', function(e) {
        if (e.target === this) this.close();
      });
    </script>
  </body>
</html>
