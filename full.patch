+    btn.addEventListener('click', async (e) => {
+      e.stopPropagation();
+      const issueId = btn.getAttribute('data-issue-id');
+      if (!issueId) return;
+      
+      btn.innerHTML = '<span class="animate-pulse">Starting...</span>';
+      
+      try {
+        const response = await fetch(`/api/issues/${issueId}/timer`, { method: 'POST' });
