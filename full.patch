+  // Live Timer Update
+  const updateTimers = () => {
+    document.querySelectorAll('.active-timer-display').forEach(display => {
+      const startStr = display.getAttribute('data-start-time');
+      if (!startStr) return;
+      
+      let dateStr = startStr;
+      if (!dateStr.endsWith('Z')) dateStr += 'Z';
+      
+      const started = new Date(dateStr).getTime();
+      const now = Date.now();
+      const elapsed = Math.floor((now - started) / 1000);
+      
+      if (elapsed < 0) return;
+      
+      const h = Math.floor(elapsed / 3600);
+      const m = Math.floor((elapsed % 3600) / 60);
+      const s = elapsed % 60;
+      
+      const textEl = display.querySelector('.timer-text');
+      if (textEl) {
+        textEl.textContent = `${h.toString().padStart(2, '0')}:${m.toString().padStart(2, '0')}:${s.toString().padStart(2, '0')}`;
+      }
+    });
+  };
+  setInterval(updateTimers, 1000);
+  updateTimers();
+
+  // Start Timer Logic
