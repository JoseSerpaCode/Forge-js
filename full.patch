+        if (data.success) {
+          if (data.stopped_previous) {
+            alert(`El timer anterior del issue ${data.stopped_details.issueId.substring(0,8).toUpperCase()} se detuvo automáticamente y se registraron ${data.stopped_details.hours}h.`);
+          }
+          
+          const card = document.getElementById(issueId);
+          const currentStatus = card?.closest('.board-column')?.getAttribute('data-status');
+          
+          if (currentStatus !== 'in_progress') {
+             await fetch(`/api/issues/${issueId}/move`, {
+               method: 'PATCH',
+               headers: { 'Content-Type': 'application/json' },
+               body: JSON.stringify({ status: 'in_progress', position: 0, workspaceId })
+             });
+          }
+          window.location.reload();
+        } else {
+          alert('Error: ' + data.message);
+          btn.innerHTML = 'Start';
